<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="#F2F6F4">

    <!-- ===================== HEADER HERO ===================== -->
    <LinearLayout
        android:id="@+id/headerSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_hero_green"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Back + judul row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_badge_white"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back"
                android:clickable="true"
                android:focusable="true"
                android:scaleType="centerInside"
                android:contentDescription="Kembali"
                android:layout_marginEnd="14dp"
                tools:ignore="TouchTargetSizeCheck"
                app:tint="#0D5C3A" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvJudul"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pengaturan"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:id="@+id/tvSubJudul"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Identitas &amp; Keamanan"
                    android:textSize="12sp"
                    android:textColor="#A8D5BC" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ===================== SCROLL CONTENT ===================== -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/headerSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnKeluar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_top_rounded"
            android:paddingHorizontal="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="16dp">

            <!-- Section Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AKUN TOKO"
                android:textSize="10sp"
                android:textColor="#0D5C3A"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="10dp" />

            <!-- Kartu: Ganti Nama Toko -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardGantiNama"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <RelativeLayout
                    android:id="@+id/rlGantiNamatoko"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <FrameLayout
                        android:id="@+id/iconBgNama"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_icon_circle_large">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_write"
                            app:tint="#0D5C3A"
                            android:scaleType="centerInside"
                            android:contentDescription="Edit Nama" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/iconBgNama"
                        android:layout_toStartOf="@id/arrowNama"
                        android:layout_centerVertical="true"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:id="@+id/tvNamaToko"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ganti Nama Toko"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Ubah identitas Toko Anda"
                            android:textSize="12sp"
                            android:textColor="#888888" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/arrowNama"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="#CCCCCC"
                        android:scaleType="centerInside"
                        android:contentDescription="Masuk" />

                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KEAMANAN"
                android:textSize="10sp"
                android:textColor="#0D5C3A"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginStart="4dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="10dp" />

            <!-- Kartu: Ganti PIN -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardGantiPin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <RelativeLayout
                    android:id="@+id/rlGantiPin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <FrameLayout
                        android:id="@+id/iconBgPin"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_icon_circle_large">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_lock"
                            app:tint="#0D5C3A"
                            android:scaleType="centerInside"
                            android:contentDescription="Ganti PIN" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/iconBgPin"
                        android:layout_toStartOf="@id/arrowPin"
                        android:layout_centerVertical="true"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ganti PIN"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Perbarui kode akses keamanan aplikasi"
                            android:textSize="12sp"
                            android:textColor="#888888" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/arrowPin"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="#CCCCCC"
                        android:scaleType="centerInside"
                        android:contentDescription="Masuk" />

                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PROFIL"
                android:textSize="10sp"
                android:textColor="#0D5C3A"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginStart="4dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="10dp" />

            <!-- Kartu: Ubah Tanggal Lahir -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardTanggalLahir"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <RelativeLayout
                    android:id="@+id/rlGantiTanggalLahir"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <FrameLayout
                        android:id="@+id/iconBgTgl"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_icon_circle_large">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_calendar"
                            app:tint="#0D5C3A"
                            android:scaleType="centerInside"
                            android:contentDescription="Tanggal Lahir" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/iconBgTgl"
                        android:layout_toStartOf="@id/arrowTgl"
                        android:layout_centerVertical="true"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ganti Tanggal Lahir"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Ubah Tanggal Lahir Anda"
                            android:textSize="12sp"
                            android:textColor="#888888" />
                    </LinearLayout>

                    <ImageView
                        android:id="@+id/arrowTgl"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="#CCCCCC"
                        android:scaleType="centerInside"
                        android:contentDescription="Masuk" />

                </RelativeLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- ===================== TOMBOL KELUAR ===================== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/btnKeluar"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="24dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        app:cardCornerRadius="20dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFF1F1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_warning"
                android:layout_marginEnd="8dp"
                app:tint="#E53935"
                android:scaleType="centerInside"
                android:contentDescription="Keluar" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reset Data Toko"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#E53935" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- RecyclerView (hidden) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvTransaksi"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerSection" />

</androidx.constraintlayout.widget.ConstraintLayout>
