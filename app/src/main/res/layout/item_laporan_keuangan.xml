<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardElevation="0dp"
    app:cardCornerRadius="20dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Icon -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_icon_circle_large"
            android:layout_marginEnd="14dp">

            <ImageView
                android:id="@+id/ivIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_money"
                android:scaleType="centerInside"
                android:contentDescription="Transaksi"
                app:tint="#0D5C3A" />
        </FrameLayout>

        <!-- Judul + Detail -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvJudulTrx"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TX-20231024"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A" />

            <TextView
                android:id="@+id/tvDetailTrx"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Penjualan • Transfer"
                android:textSize="12sp"
                android:textColor="#888888" />
        </LinearLayout>

        <!-- Nominal -->
        <TextView
            android:id="@+id/tvNominalUang"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+ Rp 150.000"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#0D5C3A" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
