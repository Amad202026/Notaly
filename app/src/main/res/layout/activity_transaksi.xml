<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Tombol Back -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:padding="8dp"
        android:src="@drawable/ic_arrow_back"
        android:clickable="true"
        android:focusable="true"
        android:scaleType="centerInside"
        android:contentDescription="Kembali"
        app:tint="#2E7D5B"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Judul -->
    <TextView
        android:id="@+id/tvJudul"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="4dp"
        android:text="Pencatatan Penjualan"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack" />

    <TextView
        android:id="@+id/tvSubJudul"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="2dp"
        android:text="Membuat transaksi"
        android:textSize="13sp"
        android:textColor="#888888"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvJudul" />

    <!-- Garis pemisah -->
    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp"
        android:background="#DDDDDD"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSubJudul" />

    <!-- ScrollView isi form -->
    <ScrollView
        android:id="@+id/ScrollForm"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/cardTotal">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <!-- ===== ITEM #1 ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ITEM #1"
                android:textSize="11sp"
                android:textColor="#2E7D5B"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:layout_marginBottom="10dp" />

            <!-- Barang -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Barang"
                android:textSize="13sp"
                android:textColor="#555555"
                android:layout_marginBottom="6dp" />

            <Spinner
                android:id="@+id/spinnerBarang"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_search_rounded"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:spinnerMode="dropdown"
                android:layout_marginBottom="14dp" />

            <!-- Harga Nego + Jumlah Terjual -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <!-- Harga Nego -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Harga Nego\n(Optional)"
                        android:textSize="13sp"
                        android:textColor="#555555"
                        android:layout_marginBottom="6dp" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_search_rounded">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical|start"
                            android:layout_marginStart="12dp"
                            android:text="Rp"
                            android:textSize="13sp"
                            android:textColor="#888888" />

                        <EditText
                            android:id="@+id/etHargaNego"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:paddingStart="36dp"
                            android:paddingEnd="10dp"
                            android:hint="0"
                            android:inputType="numberDecimal"
                            android:textSize="14sp"
                            android:textColor="#1A1A1A"
                            android:textColorHint="#AAAAAA"
                            android:background="@null"
                            android:gravity="center_vertical" />
                    </FrameLayout>
                </LinearLayout>

                <!-- Jumlah Terjual -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Jumlah Terjual"
                        android:textSize="13sp"
                        android:textColor="#555555"
                        android:layout_marginBottom="6dp" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_search_rounded">

                        <EditText
                            android:id="@+id/etJumlahTerjual"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:paddingStart="12dp"
                            android:paddingEnd="44dp"
                            android:hint="0"
                            android:inputType="number"
                            android:textSize="14sp"
                            android:textColor="#1A1A1A"
                            android:textColorHint="#AAAAAA"
                            android:background="@null"
                            android:gravity="center_vertical" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical|end"
                            android:layout_marginEnd="12dp"
                            android:text="PCS"
                            android:textSize="12sp"
                            android:textColor="#888888"
                            android:textStyle="bold" />
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Subtotal -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Subtotal"
                android:textSize="13sp"
                android:textColor="#555555"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvSubtotal"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_white_rounded"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="Rp 0"
                android:textSize="14sp"
                android:textColor="#2E7D5B"
                android:textStyle="bold"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp" />

            <!-- Tambah Item -->
            <Button
                android:id="@+id/btnTambahItem"
                android:layout_width="wrap_content"
                android:layout_height="50dp"
                android:background="@drawable/bg_white_rounded"
                android:drawableStart="@drawable/ic_plus"
                android:drawablePadding="6dp"
                android:text="Tambah Item"
                android:textColor="#2E7D5B"
                android:textSize="13sp"
                android:layout_marginBottom="20dp" />

            <!-- Garis -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginBottom="20dp" />

            <!-- ===== METODE PEMBAYARAN ===== -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Metode Pembayaran"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="12dp" />

            <!-- Transfer Bank -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F4F7F5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="14dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_money"
                        app:tint="#2E7D5B"
                        android:scaleType="centerInside"
                        android:contentDescription="Transfer" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Transfer"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BANK CENTRAL ASIA"
                            android:textSize="11sp"
                            android:textColor="#888888"
                            android:letterSpacing="0.04" />
                    </LinearLayout>

                    <RadioButton
                        android:id="@+id/rbTransfer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="#2E7D5B" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- QRIS -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="10dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F4F7F5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="14dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_barcode"
                        app:tint="#2E7D5B"
                        android:scaleType="centerInside"
                        android:contentDescription="QRIS" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="QRIS"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SHOPEEPAY, GOPAY, OVO"
                            android:textSize="11sp"
                            android:textColor="#888888"
                            android:letterSpacing="0.04" />
                    </LinearLayout>

                    <RadioButton
                        android:id="@+id/rbQris"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="#2E7D5B" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Tunai -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F4F7F5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="14dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_money_green"
                        android:scaleType="centerInside"
                        android:contentDescription="Tunai" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tunai"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PEMBAYARAN DI KASIR"
                            android:textSize="11sp"
                            android:textColor="#888888"
                            android:letterSpacing="0.04" />
                    </LinearLayout>

                    <RadioButton
                        android:id="@+id/rbTunai"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="#2E7D5B" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Bayar DP / Lunas -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_search_rounded"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btnBayarDp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_white_rounded"
                    android:text="Bayar DP"
                    android:textColor="#1A1A1A"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnLunas"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_search_rounded"
                    android:text="Lunas"
                    android:textColor="#888888"
                    android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Card Total Penjualan (sticky bottom) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardTotal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#2E7D5B"
        app:layout_constraintBottom_toTopOf="@id/btnSimpan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOTAL PENJUALAN"
                    android:textSize="10sp"
                    android:textColor="#AADDCC"
                    android:letterSpacing="0.05" />

                <TextView
                    android:id="@+id/tvTotalPenjualan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp 0,00"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvItemTerpilih"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 Item Terpilih"
                android:textSize="11sp"
                android:textColor="#AADDCC" />

            <TextView
                android:id="@+id/tvIdTransaksi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="TX-20231024"
                android:textSize="10sp"
                android:textColor="#AADDCC" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Tombol Simpan -->
    <Button
        android:id="@+id/btnSimpan"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_btn_hijau"
        android:drawableStart="@drawable/ic_cheklis"
        android:drawablePadding="8dp"
        android:text="Simpan Transaksi Keluar"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>