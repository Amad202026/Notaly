<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Tombol Back -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:padding="8dp"
        android:src="@drawable/ic_arrow_back"
        android:clickable="true"
        android:focusable="true"
        android:scaleType="centerInside"
        android:contentDescription="Kembali"
        app:tint="#2E7D5B"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Tombol Edit (kanan atas) -->
    <ImageView
        android:id="@+id/btnEdit"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginEnd="4dp"
        android:layout_marginTop="10dp"
        android:padding="8dp"
        android:src="@drawable/ic_write"
        android:clickable="true"
        android:focusable="true"
        android:scaleType="centerInside"
        android:contentDescription="Edit"
        app:tint="#2E7D5B"
        app:layout_constraintEnd_toStartOf="@id/btnHapus"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Tombol Hapus (pojok kanan atas) -->
    <ImageView
        android:id="@+id/btnHapus"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="10dp"
        android:padding="8dp"
        android:src="@drawable/ic_delete"
        android:clickable="true"
        android:focusable="true"
        android:scaleType="centerInside"
        android:contentDescription="Hapus"
        app:tint="#D32F2F"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Label atas -->
    <TextView
        android:id="@+id/tvLabelAtas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="2dp"
        android:text="DETAIL PENGIRIMAN"
        android:textSize="11sp"
        android:textColor="#2E7D5B"
        android:textStyle="bold"
        android:letterSpacing="0.06"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack" />

    <!-- Garis pemisah -->
    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:background="#DDDDDD"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvLabelAtas" />

    <!-- ScrollView -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="40dp">

            <!-- Status Header Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="STATUS PENGIRIMAN"
                            android:textSize="11sp"
                            android:textColor="#888888"
                            android:letterSpacing="0.04"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvStatusPengiriman"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Diproses"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#2E7D5B"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvEstimasiTiba"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tap edit untuk memperbarui status"
                            android:textSize="12sp"
                            android:textColor="#AAAAAA" />
                    </LinearLayout>

                    <!-- Icon truk -->
                    <FrameLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_white_rounded">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_car_full_green"
                            android:scaleType="centerInside"
                            android:contentDescription="Pengiriman" />
                    </FrameLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card Detail Info -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F4F7F5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- ID Pengiriman -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ID PENGIRIMAN"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:letterSpacing="0.04"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/tvIdPengiriman"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:layout_marginBottom="14dp" />

                    <!-- ID Transaksi -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ID TRANSAKSI"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:letterSpacing="0.04"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/tvIdTransaksi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:layout_marginBottom="14dp" />

                    <!-- Garis -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#DDDDDD"
                        android:layout_marginBottom="14dp" />

                    <!-- Ekspedisi -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EKSPEDISI"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:letterSpacing="0.04"
                        android:layout_marginBottom="2dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_cheklis_full_green"
                            android:scaleType="centerInside"
                            android:layout_marginEnd="6dp"
                            android:contentDescription="Verified" />

                        <TextView
                            android:id="@+id/tvEkspedisi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A" />
                    </LinearLayout>

                    <!-- Nomor Resi -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NOMOR RESI"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:letterSpacing="0.04"
                        android:layout_marginBottom="2dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_search_rounded"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="10dp"
                        android:layout_marginBottom="14dp">

                        <TextView
                            android:id="@+id/tvNomorResi"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="-"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A" />

                        <ImageView
                            android:id="@+id/ivSalinResi"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:src="@drawable/ic_salin"
                            app:tint="#2E7D5B"
                            android:scaleType="centerInside"
                            android:clickable="true"
                            android:focusable="true"
                            android:padding="8dp"
                            android:contentDescription="Salin Resi" />
                    </LinearLayout>

                    <!-- Alamat Lengkap -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ALAMAT TUJUAN"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:letterSpacing="0.04"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/tvAlamatLengkap"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="-"
                        android:textSize="14sp"
                        android:textColor="#1A1A1A"
                        android:layout_marginBottom="14dp" />

                    <!-- Garis -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#DDDDDD"
                        android:layout_marginBottom="14dp" />

                    <!-- Status Badge -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="STATUS PENGIRIMAN"
                            android:textSize="11sp"
                            android:textColor="#888888"
                            android:letterSpacing="0.04" />

                        <TextView
                            android:id="@+id/tvStatusBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Diproses"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#2E7D5B"
                            android:background="@drawable/bg_white_rounded"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card Rincian Biaya -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F4F7F5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RINCIAN BIAYA"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:letterSpacing="0.04"
                        android:layout_marginBottom="12dp" />

                    <!-- Biaya Kirim -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Ongkos Kirim"
                            android:textSize="13sp"
                            android:textColor="#555555" />

                        <TextView
                            android:id="@+id/tvBiayaKirim"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rp 0"
                            android:textSize="13sp"
                            android:textColor="#1A1A1A" />
                    </LinearLayout>

                    <!-- Garis -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#DDDDDD"
                        android:layout_marginBottom="12dp" />

                    <!-- Total -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Total Ongkos Kirim"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A" />

                        <TextView
                            android:id="@+id/tvTotalOngkir"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rp 0"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#2E7D5B" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>