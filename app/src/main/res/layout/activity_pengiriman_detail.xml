<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="#F2F6F4">

    <!-- ===================== HERO HEADER ===================== -->
    <LinearLayout
        android:id="@+id/headerSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_hero_green"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="28dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Back + Edit + Hapus -->
        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <ImageView android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp"
                tools:ignore="TouchTargetSizeCheck" android:background="@drawable/bg_badge_white" android:padding="8dp"
                android:src="@drawable/ic_arrow_back" android:clickable="true" android:focusable="true"
                android:scaleType="centerInside" android:contentDescription="Kembali"
                android:layout_alignParentStart="true" app:tint="#0D5C3A" />

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_alignParentEnd="true" android:orientation="horizontal">
                <ImageView android:id="@+id/btnEdit" android:layout_width="40dp" android:layout_height="40dp"
                    tools:ignore="TouchTargetSizeCheck" android:background="@drawable/bg_badge_white" android:padding="9dp"
                    android:src="@drawable/ic_write" android:scaleType="centerInside"
                    android:clickable="true" android:focusable="true" android:contentDescription="Edit"
                    android:layout_marginEnd="8dp" app:tint="#0D5C3A" />
                <ImageView android:id="@+id/btnHapus" android:layout_width="40dp" android:layout_height="40dp"
                    tools:ignore="TouchTargetSizeCheck" android:background="@drawable/bg_badge_white" android:padding="9dp"
                    android:src="@drawable/ic_delete" android:scaleType="centerInside"
                    android:clickable="true" android:focusable="true" android:contentDescription="Hapus"
                    app:tint="#E53935" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Icon Truk + Status besar -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">

            <FrameLayout android:layout_width="64dp" android:layout_height="64dp"
                android:background="@drawable/bg_badge_white" android:layout_marginEnd="16dp">
                <ImageView android:layout_width="36dp" android:layout_height="36dp"
                    android:layout_gravity="center" android:src="@drawable/ic_kirimbarang"
                    android:scaleType="centerInside" android:contentDescription="Pengiriman"
                    app:tint="#0D5C3A" />
            </FrameLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="DETAIL PENGIRIMAN" android:textSize="10sp"
                    android:textColor="#A8D5BC" android:textStyle="bold" android:letterSpacing="0.08"
                    android:layout_marginBottom="4dp" />

                <TextView android:id="@+id/tvStatusPengiriman" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="Diproses"
                    android:textColor="#FFFFFF" android:textSize="24sp" android:textStyle="bold" />

                <TextView android:id="@+id/tvEstimasiTiba" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:layout_marginTop="2dp"
                    android:text="Tap edit untuk memperbarui status"
                    android:textColor="#A8D5BC" android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Status Badge -->
        <TextView android:id="@+id/tvStatusBadge" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="● DIPROSES"
            android:textSize="11sp" android:textStyle="bold" android:textColor="#0D5C3A"
            android:background="@drawable/bg_chip_green"
            android:paddingHorizontal="14dp" android:paddingVertical="6dp" />

    </LinearLayout>

    <!-- ===================== SCROLL CONTENT ===================== -->
    <ScrollView android:layout_width="0dp" android:layout_height="0dp"
        android:overScrollMode="never" android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/headerSection"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/bg_card_top_rounded"
            android:paddingHorizontal="16dp" android:paddingTop="24dp" android:paddingBottom="40dp">

            <!-- Section: Identitas Pengiriman -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                <View android:layout_width="3dp" android:layout_height="16dp"
                    android:background="@drawable/bg_btn_hijau_round" android:layout_marginEnd="10dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="IDENTITAS PENGIRIMAN" android:textSize="10sp"
                    android:textColor="#0D5C3A" android:textStyle="bold" android:letterSpacing="0.08" />
            </LinearLayout>

            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="20dp" app:cardCornerRadius="20dp" app:cardElevation="0dp" app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">

                    <!-- ID Pengiriman -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                        <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                            android:background="@drawable/bg_icon_circle" android:layout_marginEnd="14dp">
                            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                android:layout_gravity="center" android:src="@drawable/ic_barcode_id"
                                app:tint="#0D5C3A" android:contentDescription="ID" />
                        </FrameLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="ID PENGIRIMAN" android:textColor="#AAAAAA"
                                android:textSize="10sp" android:letterSpacing="0.06" android:layout_marginBottom="2dp" />
                            <TextView android:id="@+id/tvIdPengiriman" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="-"
                                android:textColor="#1A1A1A" android:textSize="15sp" android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" android:layout_marginBottom="16dp" />

                    <!-- ID Transaksi -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                        <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                            android:background="@drawable/bg_icon_circle" android:layout_marginEnd="14dp">
                            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                android:layout_gravity="center" android:src="@drawable/ic_transaksi"
                                app:tint="#0D5C3A" android:contentDescription="Transaksi" />
                        </FrameLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="ID TRANSAKSI" android:textColor="#AAAAAA"
                                android:textSize="10sp" android:letterSpacing="0.06" android:layout_marginBottom="2dp" />
                            <TextView android:id="@+id/tvIdTransaksi" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="-"
                                android:textColor="#1A1A1A" android:textSize="15sp" android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" android:layout_marginBottom="16dp" />

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                            android:background="@drawable/bg_icon_circle" android:layout_marginEnd="14dp">
                            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                android:layout_gravity="center" android:src="@drawable/ic_calendar"
                                app:tint="#0D5C3A" android:contentDescription="Tanggal" />
                        </FrameLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="TANGGAL PENGIRIMAN" android:textColor="#AAAAAA"
                                android:textSize="10sp" android:letterSpacing="0.06" android:layout_marginBottom="2dp" />
                            <TextView android:id="@+id/tvTanggalPengiriman" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="-"
                                android:textColor="#1A1A1A" android:textSize="15sp" android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section: Detail Ekspedisi -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                <View android:layout_width="3dp" android:layout_height="16dp"
                    android:background="@drawable/bg_btn_hijau_round" android:layout_marginEnd="10dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="DETAIL EKSPEDISI" android:textSize="10sp"
                    android:textColor="#0D5C3A" android:textStyle="bold" android:letterSpacing="0.08" />
            </LinearLayout>

            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="20dp" app:cardCornerRadius="20dp" app:cardElevation="0dp" app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">

                    <!-- Ekspedisi -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                        <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                            android:background="@drawable/bg_icon_circle" android:layout_marginEnd="14dp">
                            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                android:layout_gravity="center" android:src="@drawable/ic_kirimbarang"
                                app:tint="#0D5C3A" android:contentDescription="Ekspedisi" />
                        </FrameLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="EKSPEDISI" android:textColor="#AAAAAA"
                                android:textSize="10sp" android:letterSpacing="0.06" android:layout_marginBottom="2dp" />
                            <TextView android:id="@+id/tvEkspedisi" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="-"
                                android:textColor="#1A1A1A" android:textSize="15sp" android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" android:layout_marginBottom="16dp" />

                    <!-- Nomor Resi (dengan tombol salin) -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                        <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                            android:background="@drawable/bg_icon_circle" android:layout_marginEnd="14dp">
                            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                android:layout_gravity="center" android:src="@drawable/ic_salin"
                                app:tint="#0D5C3A" android:contentDescription="Resi" />
                        </FrameLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="NOMOR RESI" android:textColor="#AAAAAA"
                                android:textSize="10sp" android:letterSpacing="0.06" android:layout_marginBottom="2dp" />
                            <TextView android:id="@+id/tvNomorResi" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="-"
                                android:textColor="#1A1A1A" android:textSize="15sp" android:textStyle="bold" />
                        </LinearLayout>
                        <FrameLayout tools:ignore="TouchTargetSizeCheck" android:layout_width="36dp" android:layout_height="36dp"
                            android:background="@drawable/bg_chip_green" android:clickable="true" android:focusable="true">
                            <ImageView android:id="@+id/ivSalinResi" android:layout_width="16dp" android:layout_height="16dp"
                                android:layout_gravity="center" android:src="@drawable/ic_salin"
                                app:tint="#0D5C3A" android:contentDescription="Salin" />
                        </FrameLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" android:layout_marginBottom="16dp" />

                    <!-- Alamat Tujuan -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="top">
                        <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                            android:background="@drawable/bg_icon_circle" android:layout_marginEnd="14dp">
                            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                android:layout_gravity="center" android:src="@drawable/ic_location"
                                app:tint="#0D5C3A" android:contentDescription="Alamat" />
                        </FrameLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="ALAMAT TUJUAN" android:textColor="#AAAAAA"
                                android:textSize="10sp" android:letterSpacing="0.06" android:layout_marginBottom="2dp" />
                            <TextView android:id="@+id/tvAlamatLengkap" android:layout_width="match_parent"
                                android:layout_height="wrap_content" android:text="-"
                                android:textColor="#1A1A1A" android:textSize="14sp" android:lineSpacingExtra="3dp" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Section: Rincian Biaya -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                <View android:layout_width="3dp" android:layout_height="16dp"
                    android:background="@drawable/bg_btn_hijau_round" android:layout_marginEnd="10dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="RINCIAN BIAYA" android:textSize="10sp"
                    android:textColor="#0D5C3A" android:textStyle="bold" android:letterSpacing="0.08" />
            </LinearLayout>

            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="20dp" app:cardElevation="0dp" app:cardBackgroundColor="#0D5C3A">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:padding="20dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="TOTAL ONGKOS KIRIM" android:textColor="#A8D5BC"
                            android:textSize="9sp" android:textStyle="bold" android:letterSpacing="0.06"
                            android:layout_marginBottom="4dp" />
                        <TextView android:id="@+id/tvTotalOngkir" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="Rp 0"
                            android:textColor="#FFFFFF" android:textSize="24sp" android:textStyle="bold"
                            android:letterSpacing="-0.02" />
                    </LinearLayout>

                    <FrameLayout android:layout_width="40dp" android:layout_height="40dp"
                        android:background="@drawable/bg_badge_white">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp"
                            android:layout_gravity="center" android:src="@drawable/ic_money"
                            android:contentDescription="Biaya" app:tint="#0D5C3A" />
                    </FrameLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
