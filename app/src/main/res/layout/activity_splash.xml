<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!--
        SPLASH SCREEN – Notaly
        Logo scale up dari kecil → normal (center)
        Teks "notaly" muncul satu per satu (typewriter)
        Tagline fade in setelah teks selesai
        Total ~1.5 detik lalu navigasi
    -->

    <!-- Logo -->
    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/ic_logo_notaly"
        android:scaleType="fitCenter"
        android:contentDescription="Logo Notaly"
        android:alpha="0"
        android:scaleX="0.3"
        android:scaleY="0.3"
        app:layout_constraintBottom_toTopOf="@id/tvAppName"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.42" />

    <!-- Nama app — diisi karakter per karakter dari Kotlin -->
    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:alpha="1"
        android:text=""
        android:textColor="#0D5C3A"
        android:textSize="38sp"
        android:textStyle="bold"
        android:letterSpacing="-0.02"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintBottom_toTopOf="@id/tvTagline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivLogo" />

    <!-- Cursor kedip saat typewriter berjalan -->
    <TextView
        android:id="@+id/tvCursor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="|"
        android:textColor="#0D5C3A"
        android:textSize="38sp"
        android:textStyle="bold"
        android:alpha="0"
        app:layout_constraintStart_toEndOf="@id/tvAppName"
        app:layout_constraintTop_toTopOf="@id/tvAppName"
        app:layout_constraintBottom_toBottomOf="@id/tvAppName" />

    <!-- Tagline -->
    <TextView
        android:id="@+id/tvTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:alpha="0"
        android:text="note and tally"
        android:textColor="#4CAF50"
        android:textSize="14sp"
        android:letterSpacing="0.04"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvAppName" />

</androidx.constraintlayout.widget.ConstraintLayout>
