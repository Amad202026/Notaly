<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="#FFFFFF"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="16dp"
            android:elevation="2dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back"
                android:scaleType="centerInside"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Kembali"
                app:tint="#2E7D5B"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="DETAIL SUPPLIER"
                android:textColor="#333333"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <!-- Tombol Edit -->
            <ImageView
                android:id="@+id/btnEdit"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:padding="8dp"
                android:src="@drawable/ic_write"
                android:scaleType="centerInside"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Edit"
                app:tint="#2E7D5B"
                android:layout_marginEnd="4dp" />

            <!-- Tombol Hapus -->
            <ImageView
                android:id="@+id/btnHapus"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:padding="8dp"
                android:src="@drawable/ic_delete"
                android:scaleType="centerInside"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Hapus"
                app:tint="#E53935" />
        </LinearLayout>

        <!-- Profile Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="28dp"
            android:paddingBottom="24dp"
            android:paddingHorizontal="24dp"
            android:background="#FFFFFF">

            <!-- Avatar bulat -->
            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_search_rounded"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvAvatarInisial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="S"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#2E7D5B" />
            </FrameLayout>

            <!-- Nama Supplier -->
            <TextView
                android:id="@+id/tvNamaSupplier"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Supplier"
                android:textColor="#1A1A1A"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <!-- Badge Kategori + ID -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:id="@+id/tvBadgeKategori"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SUPPLIER"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="#2E7D5B"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvIdSupplier"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ID: -"
                    android:textColor="#888888"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- WhatsApp -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WhatsApp"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/btnHubungiWa"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hubungi Sekarang"
                    android:textColor="#2E7D5B"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:focusable="true" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvNoWa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:textColor="#2E7D5B"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:background="#F5F5F5" />

        <!-- Informasi Dasar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INFORMASI DASAR"
                android:textColor="#555555"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="10dp" />

            <!-- Card Detail -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- Nama Lengkap -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NAMA SUPPLIER"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp"
                            android:letterSpacing="0.04"
                            android:layout_marginBottom="3dp" />

                        <TextView
                            android:id="@+id/tvDetailNama"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="#1A1A1A"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Garis -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F0F0"
                        android:layout_marginBottom="16dp" />

                    <!-- ID Supplier -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ID SUPPLIER"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp"
                            android:letterSpacing="0.04"
                            android:layout_marginBottom="3dp" />

                        <TextView
                            android:id="@+id/tvDetailId"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="#1A1A1A"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Garis -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F0F0"
                        android:layout_marginBottom="16dp" />

                    <!-- Nomor WA -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NOMOR WHATSAPP"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp"
                            android:letterSpacing="0.04"
                            android:layout_marginBottom="3dp" />

                        <TextView
                            android:id="@+id/tvDetailWa"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="#1A1A1A"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Garis -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F0F0"
                        android:layout_marginBottom="16dp" />

                    <!-- Kategori Suplai -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="KATEGORI SUPLAI"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp"
                            android:letterSpacing="0.04"
                            android:layout_marginBottom="3dp" />

                        <TextView
                            android:id="@+id/tvDetailKategori"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="#2E7D5B"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Garis -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F0F0"
                        android:layout_marginBottom="16dp" />

                    <!-- Asal Daerah -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ASAL DAERAH"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp"
                            android:letterSpacing="0.04"
                            android:layout_marginBottom="3dp" />

                        <TextView
                            android:id="@+id/tvDetailAsalDaerah"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="#1A1A1A"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Tombol Hubungi via WA (bawah) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingBottom="28dp">

            <Button
                android:id="@+id/btnWhatsapp"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_btn_hijau"
                android:drawableStart="@drawable/ic_add"
                android:drawablePadding="8dp"
                android:text="Hubungi via WhatsApp"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>