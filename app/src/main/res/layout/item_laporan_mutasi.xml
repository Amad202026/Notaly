<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardElevation="0dp"
    app:cardCornerRadius="20dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Ikon arah mutasi (masuk/keluar) -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_mutasi_out"
            android:layout_marginEnd="14dp">

            <ImageView
                android:id="@+id/ivStatusStok"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow_down"
                android:scaleType="centerInside"
                android:contentDescription="Keluar"
                app:tint="#E53935" />
        </FrameLayout>

        <!-- Nama + Waktu -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNamaBarangMutasi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Barang"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A" />

            <TextView
                android:id="@+id/tvWaktuMutasi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Pukul 14:30"
                android:textSize="11sp"
                android:textColor="#888888" />
        </LinearLayout>

        <!-- Qty delta -->
        <TextView
            android:id="@+id/tvQtyMutasi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="- 2 pcs"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#E53935" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
