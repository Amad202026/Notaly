<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="#F2F6F4">

    <!-- ===================== HERO HEADER (DETAIL) ===================== -->
    <LinearLayout
        android:id="@+id/headerSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_hero_green"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="28dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Top row: Back + Edit + Hapus -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_badge_white"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back"
                android:clickable="true"
                android:focusable="true"
                android:scaleType="centerInside"
                android:contentDescription="Kembali"
                android:layout_alignParentStart="true"
                tools:ignore="TouchTargetSizeCheck"
                app:tint="#0D5C3A" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/btnEditTop"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_badge_white"
                    android:padding="9dp"
                    android:src="@drawable/ic_write"
                    android:scaleType="centerInside"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Edit"
                    android:layout_marginEnd="8dp"
                    tools:ignore="TouchTargetSizeCheck"
                    app:tint="#0D5C3A" />

                <ImageView
                    android:id="@+id/btnHapusTop"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_badge_white"
                    android:padding="9dp"
                    android:src="@drawable/ic_delete"
                    android:scaleType="centerInside"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Hapus"
                    tools:ignore="TouchTargetSizeCheck"
                    app:tint="#E53935" />

            </LinearLayout>

        </RelativeLayout>

        <!-- Nama Barang -->
        <TextView
            android:id="@+id/tvHeaderNama"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama Barang"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="-0.01"
            android:layout_marginBottom="10dp" />

        <!-- Badge Kategori + ID -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:id="@+id/tvBadgeKategori"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KATEGORI"
                android:textColor="#0D5C3A"
                android:textSize="10sp"
                android:textStyle="bold"
                android:background="@drawable/bg_badge_white"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:layout_marginEnd="10dp"
                android:letterSpacing="0.05" />

            <TextView
                android:id="@+id/tvHeaderId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ID: -"
                android:textColor="#A8D5BC"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Stok besar -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total Stok Tersedia"
            android:textColor="#A8D5BC"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvHeaderStok"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 Pcs"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02" />

    </LinearLayout>

    <!-- ===================== SCROLL CONTENT ===================== -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/headerSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_top_rounded"
            android:paddingHorizontal="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="40dp">

            <!-- ===== INFORMASI HARGA ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="16dp"
                    android:background="@drawable/bg_btn_hijau_round"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INFORMASI HARGA"
                    android:textSize="10sp"
                    android:textColor="#0D5C3A"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Harga Modal -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="HARGA MODAL"
                                android:textColor="#AAAAAA"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.06"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tvDetailHargaModal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rp 0"
                                android:textColor="#1A1A1A"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_icon_circle">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_money"
                                android:contentDescription="Modal"
                                app:tint="#0D5C3A" />
                        </FrameLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginBottom="16dp" />

                    <!-- Harga Jual -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="HARGA JUAL (SATUAN)"
                                android:textColor="#AAAAAA"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.06"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tvDetailHargaJual"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rp 0"
                                android:textColor="#0D5C3A"
                                android:textSize="18sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_chip_green"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="UTAMA"
                            android:textSize="9sp"
                            android:textColor="#0D5C3A"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginBottom="16dp" />

                    <!-- Harga Grosir -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HARGA GROSIR"
                            android:textColor="#AAAAAA"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.06"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tvDetailHargaGrosir"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rp 0"
                            android:textColor="#F57C00"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== STATUS & KONDISI ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="16dp"
                    android:background="@drawable/bg_btn_hijau_round"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STATUS &amp; KONDISI"
                    android:textSize="10sp"
                    android:textColor="#0D5C3A"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Status Penjualan -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="STATUS PENJUALAN"
                                android:textColor="#AAAAAA"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.06"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tvDetailStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Normal"
                                android:textColor="#1A1A1A"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_chip_green"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:text="● AKTIF"
                            android:textSize="10sp"
                            android:textColor="#0D5C3A"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginBottom="16dp" />

                    <!-- Barang Rusak -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="JUMLAH BARANG RUSAK"
                                android:textColor="#AAAAAA"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.06"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tvDetailBarangRusak"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 Pcs"
                                android:textColor="#E53935"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_delete_btn">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_barangcacat"
                                android:contentDescription="Rusak"
                                app:tint="#E53935" />
                        </FrameLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
