<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Tombol Back -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:padding="8dp"
        android:src="@drawable/ic_arrow_back"
        android:clickable="true"
        android:focusable="true"
        android:scaleType="centerInside"
        android:contentDescription="Kembali"
        app:tint="#2E7D5B"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Label atas kecil -->
    <TextView
        android:id="@+id/tvLabelAtas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="2dp"
        android:text="TAMBAH KATEGORI BARANG"
        android:textSize="11sp"
        android:textColor="#2E7D5B"
        android:textStyle="bold"
        android:letterSpacing="0.06"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack" />

    <!-- Judul -->
    <TextView
        android:id="@+id/tvJudul"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="4dp"
        android:text="Tambah Kategori Barang"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvLabelAtas" />

    <!-- Subjudul -->
    <TextView
        android:id="@+id/tvSubJudul"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="4dp"
        android:text="Lengkapi detail informasi untuk mendaftarkan barang baru ke dalam sistem ledger digital."
        android:textSize="13sp"
        android:textColor="#888888"
        android:lineSpacingExtra="2dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvJudul" />

    <!-- Garis pemisah -->
    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:background="#DDDDDD"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSubJudul" />

    <!-- ScrollView -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="32dp">

            <!-- ===== IDENTITAS PRODUK ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="16dp"
                    android:background="#2E7D5B"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IDENTITAS PRODUK"
                    android:textSize="11sp"
                    android:textColor="#2E7D5B"
                    android:textStyle="bold"
                    android:letterSpacing="0.06" />
            </LinearLayout>

            <!-- Kode Barang -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kode Barang"
                android:textSize="13sp"
                android:textColor="#555555"
                android:layout_marginBottom="6dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_search_rounded"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/etKodeBarang"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="14dp"
                    android:paddingEnd="48dp"
                    android:hint="ID-0000"
                    android:textSize="14sp"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#AAAAAA"
                    android:background="@null"
                    android:gravity="center_vertical" />

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="14dp"
                    android:src="@drawable/ic_barcode_id"
                    app:tint="#AAAAAA"
                    android:scaleType="centerInside"
                    android:contentDescription="Barcode" />
            </FrameLayout>

            <!-- Kategori -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kategori"
                android:textSize="13sp"
                android:textColor="#555555"
                android:layout_marginBottom="6dp" />

            <Spinner
                android:id="@+id/spinnerKategori"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_search_rounded"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:spinnerMode="dropdown"
                android:layout_marginBottom="16dp" />

            <!-- Nama Barang -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Barang"
                android:textSize="13sp"
                android:textColor="#555555"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etNamaBarang"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_search_rounded"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:hint="Contoh: Jersey Sepak Bola"
                android:textSize="14sp"
                android:textColor="#1A1A1A"
                android:textColorHint="#AAAAAA"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp" />

            <!-- ===== SKEMA HARGA ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="16dp"
                    android:background="#2E7D5B"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SKEMA HARGA (IDR)"
                    android:textSize="11sp"
                    android:textColor="#2E7D5B"
                    android:textStyle="bold"
                    android:letterSpacing="0.06" />
            </LinearLayout>

            <!-- Harga Modal -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Harga modal"
                android:textSize="13sp"
                android:textColor="#555555"
                android:layout_marginBottom="6dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_search_rounded"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="14dp"
                    android:text="Rp"
                    android:textSize="14sp"
                    android:textColor="#888888" />

                <EditText
                    android:id="@+id/etHargaModal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="40dp"
                    android:paddingEnd="14dp"
                    android:hint="0"
                    android:inputType="numberDecimal"
                    android:textSize="14sp"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#AAAAAA"
                    android:background="@null"
                    android:gravity="center_vertical" />
            </FrameLayout>

            <!-- Harga Jual Normal - highlighted -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Harga Jual (Normal)"
                android:textSize="13sp"
                android:textColor="#2E7D5B"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_white_rounded"
                android:layout_marginBottom="12dp">

                <!-- Outline hijau tipis simulasi selected -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="14dp"
                    android:text="Rp"
                    android:textSize="14sp"
                    android:textColor="#2E7D5B" />

                <EditText
                    android:id="@+id/etHargaJual"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="40dp"
                    android:paddingEnd="14dp"
                    android:hint="0"
                    android:inputType="numberDecimal"
                    android:textSize="14sp"
                    android:textColor="#2E7D5B"
                    android:textColorHint="#AAAAAA"
                    android:background="@null"
                    android:gravity="center_vertical" />
            </FrameLayout>

            <!-- Harga Grosir -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Harga Grosir"
                android:textSize="13sp"
                android:textColor="#555555"
                android:layout_marginBottom="6dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_search_rounded"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="14dp"
                    android:text="Rp"
                    android:textSize="14sp"
                    android:textColor="#888888" />

                <EditText
                    android:id="@+id/etHargaGrosir"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="40dp"
                    android:paddingEnd="14dp"
                    android:hint="0"
                    android:inputType="numberDecimal"
                    android:textSize="14sp"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#AAAAAA"
                    android:background="@null"
                    android:gravity="center_vertical" />
            </FrameLayout>

            <!-- ===== MANAJEMEN STOK ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="16dp"
                    android:background="#2E7D5B"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MANAJEMEN STOK"
                    android:textSize="11sp"
                    android:textColor="#2E7D5B"
                    android:textStyle="bold"
                    android:letterSpacing="0.06" />
            </LinearLayout>

            <!-- Stok Awal -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Stok Awal"
                android:textSize="13sp"
                android:textColor="#555555"
                android:layout_marginBottom="6dp" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_search_rounded"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/etStokAwal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="14dp"
                    android:paddingEnd="60dp"
                    android:hint="0"
                    android:inputType="number"
                    android:textSize="14sp"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#AAAAAA"
                    android:background="@null"
                    android:gravity="center_vertical" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="14dp"
                    android:text="Pcs"
                    android:textSize="13sp"
                    android:textColor="#888888" />
            </FrameLayout>

            <!-- Tombol Simpan -->
            <Button
                android:id="@+id/btnSimpan"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_btn_hijau"
                android:text="Simpan Barang"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>