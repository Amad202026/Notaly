<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="#F2F6F4">

    <!-- ===================== HEADER HERO ===================== -->
    <LinearLayout
        android:id="@+id/headerSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_hero_green"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_badge_white"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back"
                android:clickable="true"
                android:focusable="true"
                android:scaleType="centerInside"
                android:contentDescription="Kembali"
                android:layout_marginEnd="14dp"
                tools:ignore="TouchTargetSizeCheck"
                app:tint="#0D5C3A" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvLabelAtas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip_green"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="3dp"
                    android:text="BARANG BARU"
                    android:textSize="9sp"
                    android:textColor="#0D5C3A"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tvJudul"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tambah Barang"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:id="@+id/tvSubJudul"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Daftarkan barang baru ke sistem"
                    android:textSize="12sp"
                    android:textColor="#A8D5BC" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ===================== SCROLL FORM ===================== -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/headerSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_top_rounded"
            android:paddingHorizontal="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="40dp">

            <!-- ===== SECTION: IDENTITAS PRODUK ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="16dp"
                    android:background="@drawable/bg_btn_hijau_round"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IDENTITAS PRODUK"
                    android:textSize="10sp"
                    android:textColor="#0D5C3A"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Kode Barang -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KODE BARANG"
                        android:textSize="10sp"
                        android:textColor="#0D5C3A"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="8dp" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_input_outline"
                        android:layout_marginBottom="16dp">

                        <EditText
                            android:id="@+id/etKodeBarang"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:paddingStart="16dp"
                            android:paddingEnd="48dp"
                            android:hint="ID-0000"
                            android:textSize="14sp"
                            android:textColor="#1A1A1A"
                            android:textColorHint="#BBBBBB"
                            android:background="@null"
                            android:gravity="center_vertical" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center_vertical|end"
                            android:layout_marginEnd="16dp"
                            android:src="@drawable/ic_barcode_id"
                            app:tint="#BBBBBB"
                            android:scaleType="centerInside"
                            android:contentDescription="Barcode" />
                    </FrameLayout>

                    <!-- Kategori -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KATEGORI"
                        android:textSize="10sp"
                        android:textColor="#0D5C3A"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="8dp" />

                    <Spinner
                        android:id="@+id/spinnerKategori"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_input_outline"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:spinnerMode="dropdown"
                        android:layout_marginBottom="16dp" />

                    <!-- Nama Barang -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NAMA BARANG"
                        android:textSize="10sp"
                        android:textColor="#0D5C3A"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/etNamaBarang"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_input_outline"
                        android:paddingHorizontal="16dp"
                        android:hint="Contoh: Jersey Sepak Bola"
                        android:textSize="14sp"
                        android:textColor="#1A1A1A"
                        android:textColorHint="#BBBBBB"
                        android:gravity="center_vertical"
                        android:inputType="textCapWords"
                        android:singleLine="true" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== SECTION: SKEMA HARGA ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="16dp"
                    android:background="@drawable/bg_btn_hijau_round"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SKEMA HARGA (IDR)"
                    android:textSize="10sp"
                    android:textColor="#0D5C3A"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Harga Modal -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HARGA MODAL"
                        android:textSize="10sp"
                        android:textColor="#888888"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="8dp" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_input_outline"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical|start"
                            android:layout_marginStart="16dp"
                            android:text="Rp"
                            android:textSize="14sp"
                            android:textColor="#AAAAAA" />

                        <EditText
                            android:id="@+id/etHargaModal"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:paddingStart="44dp"
                            android:paddingEnd="16dp"
                            android:hint="0"
                            android:inputType="numberDecimal"
                            android:textSize="14sp"
                            android:textColor="#1A1A1A"
                            android:textColorHint="#BBBBBB"
                            android:background="@null"
                            android:gravity="center_vertical" />
                    </FrameLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F0F0"
                        android:layout_marginBottom="16dp" />

                    <!-- Harga Jual — highlighted -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="HARGA JUAL (NORMAL)"
                            android:textSize="10sp"
                            android:textColor="#0D5C3A"
                            android:textStyle="bold"
                            android:letterSpacing="0.08" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_chip_green"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="3dp"
                            android:text="UTAMA"
                            android:textSize="9sp"
                            android:textColor="#0D5C3A"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_input_green_outline"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical|start"
                            android:layout_marginStart="16dp"
                            android:text="Rp"
                            android:textSize="14sp"
                            android:textColor="#0D5C3A" />

                        <EditText
                            android:id="@+id/etHargaJual"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:paddingStart="44dp"
                            android:paddingEnd="16dp"
                            android:hint="0"
                            android:inputType="numberDecimal"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#0D5C3A"
                            android:textColorHint="#BBBBBB"
                            android:background="@null"
                            android:gravity="center_vertical" />
                    </FrameLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F0F0"
                        android:layout_marginBottom="16dp" />

                    <!-- Harga Grosir -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HARGA GROSIR"
                        android:textSize="10sp"
                        android:textColor="#888888"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="8dp" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_input_outline">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical|start"
                            android:layout_marginStart="16dp"
                            android:text="Rp"
                            android:textSize="14sp"
                            android:textColor="#AAAAAA" />

                        <EditText
                            android:id="@+id/etHargaGrosir"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:paddingStart="44dp"
                            android:paddingEnd="16dp"
                            android:hint="0"
                            android:inputType="numberDecimal"
                            android:textSize="14sp"
                            android:textColor="#1A1A1A"
                            android:textColorHint="#BBBBBB"
                            android:background="@null"
                            android:gravity="center_vertical" />
                    </FrameLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== SECTION: MANAJEMEN STOK ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <View
                    android:layout_width="3dp"
                    android:layout_height="16dp"
                    android:background="@drawable/bg_btn_hijau_round"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MANAJEMEN STOK"
                    android:textSize="10sp"
                    android:textColor="#0D5C3A"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STOK MINIMAL"
                        android:textSize="10sp"
                        android:textColor="#0D5C3A"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="8dp" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_input_outline">

                        <EditText
                            android:id="@+id/etStokMin"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:paddingStart="16dp"
                            android:paddingEnd="56dp"
                            android:hint="0"
                            android:inputType="number"
                            android:textSize="14sp"
                            android:textColor="#1A1A1A"
                            android:textColorHint="#BBBBBB"
                            android:background="@null"
                            android:gravity="center_vertical" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical|end"
                            android:layout_marginEnd="16dp"
                            android:text="Pcs"
                            android:textSize="13sp"
                            android:textColor="#AAAAAA"
                            android:textStyle="bold" />
                    </FrameLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Tombol Simpan -->
            <TextView
                android:id="@+id/btnSimpan"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:background="@drawable/bg_btn_hijau_round"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="Simpan Barang"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
