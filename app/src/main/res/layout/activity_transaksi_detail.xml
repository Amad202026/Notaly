<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Tombol Back -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:padding="8dp"
        android:src="@drawable/ic_arrow_back"
        android:clickable="true"
        android:focusable="true"
        android:scaleType="centerInside"
        android:contentDescription="Kembali"
        app:tint="#2E7D5B"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Label atas -->
    <TextView
        android:id="@+id/tvLabelAtas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="2dp"
        android:text="DETAIL TRANSAKSI"
        android:textSize="11sp"
        android:textColor="#2E7D5B"
        android:textStyle="bold"
        android:letterSpacing="0.06"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack" />

    <!-- Garis pemisah -->
    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:background="#DDDDDD"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvLabelAtas" />

    <!-- ScrollView -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/layoutTombol">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="12dp">

            <!-- ID Transaksi besar -->
            <TextView
                android:id="@+id/tvIdTransaksi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="001"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="16dp" />

            <!-- Card Status Transaksi -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F4F7F5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STATUS TRANSAKSI"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvStatusTransaksi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Berhasil Diselesaikan"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvTanggalTransaksi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="24 April 2026 • 14:32 WIB"
                        android:textSize="13sp"
                        android:textColor="#888888" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Header tabel produk -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="4dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="3"
                    android:text="PRODUCT"
                    android:textSize="10sp"
                    android:textColor="#AAAAAA"
                    android:letterSpacing="0.04" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="QTY"
                    android:textSize="10sp"
                    android:textColor="#AAAAAA"
                    android:gravity="center"
                    android:letterSpacing="0.04" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.8"
                    android:text="HARGA\nSATUAN"
                    android:textSize="10sp"
                    android:textColor="#AAAAAA"
                    android:gravity="center"
                    android:letterSpacing="0.04" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.8"
                    android:text="TOTAL"
                    android:textSize="10sp"
                    android:textColor="#AAAAAA"
                    android:gravity="end"
                    android:letterSpacing="0.04" />
            </LinearLayout>

            <!-- RecyclerView produk -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvProduk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                android:layout_marginBottom="12dp" />

            <!-- Garis pemisah -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginBottom="12dp" />

            <!-- Ringkasan Biaya -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="4dp">

                <!-- Subtotal -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Subtotal"
                        android:textSize="13sp"
                        android:textColor="#555555" />

                    <TextView
                        android:id="@+id/tvSubtotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 860.000"
                        android:textSize="13sp"
                        android:textColor="#1A1A1A" />
                </LinearLayout>

                <!-- Potongan -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Potonga Harga/Diskon"
                        android:textSize="13sp"
                        android:textColor="#555555" />

                    <TextView
                        android:id="@+id/tvDiskon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 0"
                        android:textSize="13sp"
                        android:textColor="#1A1A1A" />
                </LinearLayout>

                <!-- Pajak -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tax (PPN 11%)"
                        android:textSize="13sp"
                        android:textColor="#555555" />

                    <TextView
                        android:id="@+id/tvPajak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 94.600"
                        android:textSize="13sp"
                        android:textColor="#1A1A1A" />
                </LinearLayout>

                <!-- Laba -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Laba Penjualan"
                        android:textSize="13sp"
                        android:textColor="#555555" />

                    <TextView
                        android:id="@+id/tvLaba"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 125.000"
                        android:textSize="13sp"
                        android:textColor="#1A1A1A" />
                </LinearLayout>

                <!-- Garis -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE"
                    android:layout_marginBottom="12dp" />

                <!-- Total Belanja -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOTAL BELANJA"
                            android:textSize="10sp"
                            android:textColor="#2E7D5B"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/tvTotalBelanja"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rp 954.600"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="#1A1A1A" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PAID FULL"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#2E7D5B"
                        android:background="@drawable/bg_white_rounded"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Tombol Bagikan & Cetak -->
    <LinearLayout
        android:id="@+id/layoutTombol"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnBagikan"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_search_rounded"
            android:drawableStart="@drawable/ic_share"
            android:drawablePadding="6dp"
            android:text="Bagikan"
            android:textColor="#1A1A1A"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnCetakStruk"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_hijau"
            android:drawableStart="@drawable/ic_print"
            android:drawablePadding="6dp"
            android:text="Cetak Struk"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>