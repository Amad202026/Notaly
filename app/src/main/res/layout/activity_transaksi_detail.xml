<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F6F4">

    <!-- ==================== HEADER ==================== -->
    <LinearLayout
        android:id="@+id/headerSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_hero_green"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="28dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="20dp">

            <ImageView android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/bg_badge_white" android:padding="8dp"
                android:src="@drawable/ic_arrow_back" android:clickable="true" android:focusable="true"
                android:scaleType="centerInside" tools:ignore="TouchTargetSizeCheck"
                android:contentDescription="Kembali" android:layout_marginEnd="14dp" app:tint="#0D5C3A" />

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="DETAIL TRANSAKSI" android:textSize="10sp"
                    android:textColor="#A8D5BC" android:textStyle="bold" android:letterSpacing="0.08" />
            </LinearLayout>
        </LinearLayout>

        <TextView android:id="@+id/tvIdTransaksi" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="TX-001"
            android:textColor="#FFFFFF" android:textSize="34sp" android:textStyle="bold"
            android:letterSpacing="-0.02" android:layout_marginBottom="12dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_info_strip" android:orientation="horizontal"
            android:gravity="center_vertical" android:padding="12dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="STATUS" android:textColor="#0D5C3A"
                    android:textSize="9sp" android:textStyle="bold" android:letterSpacing="0.06"
                    android:layout_marginBottom="2dp" />
                <TextView android:id="@+id/tvStatusTransaksi" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="Berhasil Diselesaikan"
                    android:textColor="#0A3D26" android:textSize="14sp" android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="end">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="TANGGAL" android:textColor="#0D5C3A"
                    android:textSize="9sp" android:textStyle="bold" android:letterSpacing="0.06"
                    android:layout_marginBottom="2dp" />
                <TextView android:id="@+id/tvTanggalTransaksi" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="24 Apr 2026 • 14:32"
                    android:textColor="#0A3D26" android:textSize="12sp" android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- ==================== SCROLL CONTENT ==================== -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp" android:layout_height="0dp"
        android:overScrollMode="never" android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/headerSection"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/layoutTombolFull">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/bg_card_top_rounded"
            android:paddingHorizontal="16dp" android:paddingTop="24dp" android:paddingBottom="12dp">

            <!-- ── INFO PELANGGAN (muncul jika ada pelanggan) ── -->
            <LinearLayout
                android:id="@+id/llInfoPelanggan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <View android:layout_width="3dp" android:layout_height="16dp"
                        android:background="@drawable/bg_btn_hijau_round" android:layout_marginEnd="10dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="PELANGGAN" android:textSize="10sp"
                        android:textColor="#0D5C3A" android:textStyle="bold" android:letterSpacing="0.08" />
                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp" app:cardElevation="0dp" app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:padding="16dp">

                        <!-- Avatar inisial -->
                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_badge_green"
                            android:layout_marginEnd="14dp">
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_person"
                                app:tint="#0D5C3A"
                                android:contentDescription="Pelanggan" />
                        </FrameLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView
                                android:id="@+id/tvNamaPelanggan"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Nama Pelanggan"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="#1A1A1A" />
                            <TextView
                                android:id="@+id/tvKategoriPelanggan"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Member"
                                android:textSize="12sp"
                                android:textColor="#0D5C3A"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ── DAFTAR PRODUK ── -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <View android:layout_width="3dp" android:layout_height="16dp"
                    android:background="@drawable/bg_btn_hijau_round" android:layout_marginEnd="10dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="DAFTAR PRODUK" android:textSize="10sp"
                    android:textColor="#0D5C3A" android:textStyle="bold" android:letterSpacing="0.08" />
            </LinearLayout>

            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="4dp" app:cardCornerRadius="12dp"
                app:cardElevation="0dp" app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:paddingHorizontal="14dp" android:paddingVertical="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="3" android:text="PRODUK" android:textSize="10sp"
                        android:textColor="#0D5C3A" android:textStyle="bold" android:letterSpacing="0.06" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1.8" android:text="TOTAL" android:textSize="10sp"
                        android:textColor="#AAAAAA" android:gravity="end" android:letterSpacing="0.06" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvProduk"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" android:overScrollMode="never"
                android:layout_marginBottom="16dp" />

            <!-- ── RINGKASAN BIAYA ── -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <View android:layout_width="3dp" android:layout_height="16dp"
                    android:background="@drawable/bg_btn_hijau_round" android:layout_marginEnd="10dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="RINGKASAN BIAYA" android:textSize="10sp"
                    android:textColor="#0D5C3A" android:textStyle="bold" android:letterSpacing="0.08" />
            </LinearLayout>

            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="20dp" app:cardElevation="0dp" app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">

                    <!-- Subtotal -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Subtotal"
                            android:textSize="13sp" android:textColor="#555555" />
                        <TextView android:id="@+id/tvSubtotal" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="Rp 0"
                            android:textSize="13sp" android:textColor="#1A1A1A" />
                    </LinearLayout>

                    <!-- Diskon nego / harga -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="10dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Potongan / Diskon Nego"
                            android:textSize="13sp" android:textColor="#555555" />
                        <TextView android:id="@+id/tvDiskon" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="Rp 0"
                            android:textSize="13sp" android:textColor="#E53935" />
                    </LinearLayout>

                    <!-- Diskon pelanggan (Member/Grosir) — muncul jika ada -->
                    <LinearLayout
                        android:id="@+id/llDiskonPelanggan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp"
                        android:visibility="gone">

                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Diskon Pelanggan"
                            android:textSize="13sp" android:textColor="#555555" />

                        <TextView
                            android:id="@+id/tvDiskonPelangganPersen"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="(10%)"
                            android:textSize="11sp"
                            android:textColor="#0D5C3A"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:id="@+id/tvDiskonPelangganNominal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-Rp 0"
                            android:textSize="13sp"
                            android:textColor="#E53935" />
                    </LinearLayout>

                    <!-- Pajak -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="10dp"/>

                    <!-- Laba -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="12dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Laba Penjualan"
                            android:textSize="13sp" android:textColor="#555555" />
                        <TextView android:id="@+id/tvLaba" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="Rp 0"
                            android:textSize="13sp" android:textColor="#0D5C3A" android:textStyle="bold" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F0F0F0" android:layout_marginBottom="16dp" />

                    <!-- Total Belanja + Badge -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="TOTAL BELANJA" android:textSize="10sp"
                                android:textColor="#0D5C3A" android:textStyle="bold"
                                android:letterSpacing="0.06" android:layout_marginBottom="4dp" />
                            <TextView android:id="@+id/tvTotalBelanja" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="Rp 0"
                                android:textSize="24sp" android:textStyle="bold" android:textColor="#0A3D26"
                                android:letterSpacing="-0.02" />
                        </LinearLayout>
                        <TextView android:id="@+id/tvStatusBadge" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="PAID FULL"
                            android:textSize="11sp" android:textStyle="bold" android:textColor="#0D5C3A"
                            android:background="@drawable/bg_chip_green"
                            android:paddingHorizontal="12dp" android:paddingVertical="6dp" />
                    </LinearLayout>

                    <!-- Info DP (muncul jika status DP) -->
                    <LinearLayout
                        android:id="@+id/llInfoDp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:background="#F0F0F0" android:layout_marginVertical="16dp" />

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:layout_marginBottom="10dp">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="Telah Dibayar (DP)"
                                android:textSize="13sp" android:textColor="#555555" />
                            <TextView android:id="@+id/tvDpDibayar" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="Rp 0"
                                android:textSize="14sp" android:textStyle="bold" android:textColor="#1A1A1A" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="Sisa Tagihan"
                                android:textSize="13sp" android:textStyle="bold" android:textColor="#E53935" />
                            <TextView android:id="@+id/tvSisaTagihan" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="Rp 0"
                                android:textSize="15sp" android:textColor="#E53935" android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- ==================== TOMBOL BAWAH ==================== -->
    <LinearLayout
        android:id="@+id/layoutTombolFull"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="28dp"
        android:layout_marginTop="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btnLunasi"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_btn_hijau_round"
            android:clickable="true" android:focusable="true"
            android:gravity="center"
            android:text="Lunasi Sisa Tagihan"
            android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="56dp"
                android:layout_weight="1" android:layout_marginEnd="10dp"
                android:clickable="true" android:focusable="true"
                app:cardCornerRadius="18dp" app:cardElevation="0dp" app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:gravity="center" android:orientation="horizontal">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp"
                        android:src="@drawable/ic_share" app:tint="#1A1A1A"
                        android:layout_marginEnd="8dp" android:contentDescription="Bagikan" />
                    <TextView android:id="@+id/btnBagikan" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Bagikan"
                        android:textColor="#1A1A1A" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView android:id="@+id/btnCetakStruk" android:layout_width="0dp" android:layout_height="56dp"
                android:layout_weight="1" android:background="@drawable/bg_btn_hijau_round"
                android:clickable="true" android:focusable="true"
                android:gravity="center" android:text="Cetak Struk"
                android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>