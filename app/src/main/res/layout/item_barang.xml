<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top row: Badge kategori + Hapus -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvKategoriPill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_chip_green"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:text="KATEGORI"
                android:textColor="#0D5C3A"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.04" />

            <ImageView
                android:id="@+id/btnDelete"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="Hapus"
                android:src="@drawable/ic_delete"
                android:layout_alignParentRight="true"
                app:tint="#E53935" />

        </RelativeLayout>

        <!-- Nama Barang -->
        <TextView
            android:id="@+id/tvNamaBarang"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nama Barang"
            android:textColor="#1A1A1A"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <!-- Stok + Harga row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <!-- Stok -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_info_strip"
                android:orientation="vertical"
                android:padding="10dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STOK"
                    android:textSize="9sp"
                    android:textColor="#0D5C3A"
                    android:textStyle="bold"
                    android:letterSpacing="0.06"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tvStokBarang"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 Pcs"
                    android:textColor="#0A3D26"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Harga Jual -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_info_strip"
                android:orientation="vertical"
                android:padding="10dp"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HARGA JUAL"
                    android:textSize="9sp"
                    android:textColor="#0D5C3A"
                    android:textStyle="bold"
                    android:letterSpacing="0.06"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tvHargaBarang"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp 0"
                    android:textColor="#0D5C3A"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <!-- Tombol Detail -->
        <TextView
            android:id="@+id/btnDetail"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_btn_hijau_round"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="Lihat Detail"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
