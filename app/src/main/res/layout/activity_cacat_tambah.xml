<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Tombol Back -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:padding="8dp"
        android:src="@drawable/ic_arrow_back"
        android:clickable="true"
        android:focusable="true"
        android:scaleType="centerInside"
        android:contentDescription="Kembali"
        app:tint="#2E7D5B"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Judul -->
    <TextView
        android:id="@+id/tvJudul"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="4dp"
        android:text="Input Barang Cacat"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack" />

    <!-- Garis pemisah -->
    <View
        android:id="@+id/divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:background="#DDDDDD"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvJudul" />

    <!-- ScrollView konten form -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnSimpan">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">

            <!-- Label: Pilih Barang -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PILIH BARANG"
                android:textSize="12sp"
                android:textColor="#888888"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <!-- Dropdown Pilih Barang -->
            <Spinner
                android:id="@+id/spinnerBarang"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_search_rounded"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:spinnerMode="dropdown"
                android:prompt="@string/app_name"
                android:layout_marginBottom="24dp" />

            <!-- Label: Jumlah Barang -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JUMLAH BARANG"
                android:textSize="12sp"
                android:textColor="#888888"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <!-- Input Jumlah Barang + Pcs -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_search_rounded"
                android:layout_marginBottom="24dp">

                <EditText
                    android:id="@+id/etJumlahBarang"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="16dp"
                    android:paddingEnd="60dp"
                    android:hint="0"
                    android:inputType="number"
                    android:textSize="15sp"
                    android:textColor="#1A1A1A"
                    android:textColorHint="#AAAAAA"
                    android:background="@null"
                    android:gravity="center_vertical" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="16dp"
                    android:text="Pcs"
                    android:textSize="14sp"
                    android:textColor="#888888" />
            </FrameLayout>

            <!-- Label: Harga Barang -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HARGA BARANG"
                android:textSize="12sp"
                android:textColor="#888888"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <!-- Input Harga Barang -->
            <EditText
                android:id="@+id/etHargaBarang"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_search_rounded"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:hint="150.000"
                android:inputType="numberDecimal"
                android:textSize="15sp"
                android:textColor="#1A1A1A"
                android:textColorHint="#AAAAAA"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp" />

            <!-- Label: Keterangan Kerusakan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KETERANGAN KERUSAKAN"
                android:textSize="12sp"
                android:textColor="#888888"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <!-- Input Keterangan Kerusakan (multiline) -->
            <EditText
                android:id="@+id/etKeteranganKerusakan"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="@drawable/bg_search_rounded"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp"
                android:hint="Contoh: Jahitan lepas, noda permanen..."
                android:inputType="textMultiLine"
                android:textSize="14sp"
                android:textColor="#1A1A1A"
                android:textColorHint="#AAAAAA"
                android:gravity="top|start"
                android:lines="4"
                android:maxLines="6"
                android:scrollbars="vertical" />

        </LinearLayout>
    </ScrollView>

    <!-- Tombol Simpan Laporan -->
    <Button
        android:id="@+id/btnSimpan"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:layout_marginStart="48dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="28dp"
        android:background="@drawable/bg_btn_hijau"
        android:drawableStart="@drawable/ic_save"
        android:drawablePadding="8dp"
        android:text="Simpan Laporan"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>