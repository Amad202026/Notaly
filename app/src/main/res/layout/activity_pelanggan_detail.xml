<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="#F2F6F4">

    <!-- ===================== HERO HEADER ===================== -->
    <LinearLayout
        android:id="@+id/headerSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_hero_green"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="28dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Back + Edit + Hapus -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <ImageView
                android:id="@+id/ivBack" tools:ignore="TouchTargetSizeCheck"
                android:layout_width="40dp" android:layout_height="40dp"
                android:background="@drawable/bg_badge_white" android:padding="8dp"
                android:src="@drawable/ic_arrow_back" android:clickable="true" android:focusable="true"
                android:scaleType="centerInside" android:contentDescription="Kembali"
                android:layout_alignParentStart="true" app:tint="#0D5C3A" />

            <LinearLayout
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_alignParentEnd="true" android:orientation="horizontal">

                <ImageView android:id="@+id/tvEditBottom" android:layout_width="40dp" android:layout_height="40dp"
                    android:background="@drawable/bg_badge_white" android:padding="9dp"
                    android:src="@drawable/ic_write" android:scaleType="centerInside"
                    android:clickable="true" tools:ignore="TouchTargetSizeCheck" android:focusable="true" android:contentDescription="Edit"
                    android:layout_marginEnd="8dp" app:tint="#0D5C3A" />

                <ImageView android:id="@+id/tvHapus" android:layout_width="40dp" android:layout_height="40dp"
                    android:background="@drawable/bg_badge_white" android:padding="9dp"
                    android:src="@drawable/ic_delete" android:scaleType="centerInside"
                    android:clickable="true" android:focusable="true" android:contentDescription="Hapus"
                    app:tint="#E53935" tools:ignore="TouchTargetSizeCheck"/>
            </LinearLayout>
        </RelativeLayout>

        <!-- Avatar + Info -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">

            <FrameLayout android:layout_width="64dp" android:layout_height="64dp"
                android:background="@drawable/bg_badge_white" android:layout_marginEnd="16dp">
                <TextView android:id="@+id/tvAvatar" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:layout_gravity="center"
                    android:text="Y" android:textColor="#0D5C3A" android:textSize="26sp" android:textStyle="bold" />
            </FrameLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">

                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">

                    <TextView android:id="@+id/tvKategori" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="MEMBER"
                        android:textColor="#0D5C3A" android:textSize="10sp" android:textStyle="bold"
                        android:background="@drawable/bg_chip_green" android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp" android:layout_marginEnd="8dp" android:letterSpacing="0.05" />

                    <TextView android:id="@+id/tvId" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="ID: 001"
                        android:textColor="#A8D5BC" android:textSize="11sp" />
                </LinearLayout>

                <TextView android:id="@+id/tvNama" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="Yongki Y"
                    android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- WA Quick Contact Strip -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_info_strip" android:orientation="horizontal"
            android:gravity="center_vertical" android:padding="12dp" android:layout_marginTop="16dp"
            android:clickable="true" android:focusable="true">

            <ImageView android:layout_width="18dp" android:layout_height="18dp"
                android:src="@drawable/ic_daftarpelanggan" android:contentDescription="WA"
                app:tint="#0D5C3A" android:layout_marginEnd="10dp" />

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="WHATSAPP" android:textColor="#0D5C3A"
                    android:textSize="9sp" android:textStyle="bold" android:letterSpacing="0.06" />

                <TextView android:id="@+id/tvWaNumber" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="+62 812-3456-7890"
                    android:textColor="#0A3D26" android:textSize="14sp" android:textStyle="bold" />
            </LinearLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Hubungi →" android:textColor="#0D5C3A"
                android:textSize="12sp" android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <!-- ===================== SCROLL CONTENT ===================== -->
    <ScrollView
        android:layout_width="0dp" android:layout_height="0dp"
        android:overScrollMode="never" android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/headerSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="@drawable/bg_card_top_rounded"
            android:paddingHorizontal="16dp" android:paddingTop="24dp" android:paddingBottom="40dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                <View android:layout_width="3dp" android:layout_height="16dp"
                    android:background="@drawable/bg_btn_hijau_round" android:layout_marginEnd="10dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="INFORMASI DASAR" android:textSize="10sp"
                    android:textColor="#0D5C3A" android:textStyle="bold" android:letterSpacing="0.08" />
            </LinearLayout>

            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="20dp" app:cardElevation="0dp" app:cardBackgroundColor="#FFFFFF">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">

                    <!-- Nama -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                        <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                            android:background="@drawable/bg_icon_circle" android:layout_marginEnd="14dp">
                            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                android:layout_gravity="center" android:src="@drawable/ic_daftarpelanggan"
                                app:tint="#0D5C3A" android:contentDescription="Nama" />
                        </FrameLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="NAMA LENGKAP" android:textColor="#AAAAAA"
                                android:textSize="10sp" android:letterSpacing="0.06" android:layout_marginBottom="2dp" />
                            <TextView android:id="@+id/tvDetailNama" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="Yongki Y"
                                android:textColor="#1A1A1A" android:textSize="15sp" android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" android:layout_marginBottom="16dp" />

                    <!-- ID -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                        <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                            android:background="@drawable/bg_icon_circle" android:layout_marginEnd="14dp">
                            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                android:layout_gravity="center" android:src="@drawable/ic_barcode_id"
                                app:tint="#0D5C3A" android:contentDescription="ID" />
                        </FrameLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="ID PELANGGAN" android:textColor="#AAAAAA"
                                android:textSize="10sp" android:letterSpacing="0.06" android:layout_marginBottom="2dp" />
                            <TextView android:id="@+id/tvDetailId" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="001"
                                android:textColor="#1A1A1A" android:textSize="15sp" android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" android:layout_marginBottom="16dp" />

                    <!-- Nomor WA -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                        <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                            android:background="@drawable/bg_icon_circle" android:layout_marginEnd="14dp">
                            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                android:layout_gravity="center" android:src="@drawable/ic_daftarpelanggan"
                                app:tint="#0D5C3A" android:contentDescription="WA" />
                        </FrameLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="NOMOR WHATSAPP" android:textColor="#AAAAAA"
                                android:textSize="10sp" android:letterSpacing="0.06" android:layout_marginBottom="2dp" />
                            <TextView android:id="@+id/tvDetailWa" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="+62 812-3456-7890"
                                android:textColor="#1A1A1A" android:textSize="15sp" android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" android:layout_marginBottom="16dp" />

                    <!-- Asal Daerah -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                        <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                            android:background="@drawable/bg_icon_circle" android:layout_marginEnd="14dp">
                            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                android:layout_gravity="center" android:src="@drawable/ic_location"
                                app:tint="#0D5C3A" android:contentDescription="Lokasi" />
                        </FrameLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="ASAL DAERAH" android:textColor="#AAAAAA"
                                android:textSize="10sp" android:letterSpacing="0.06" android:layout_marginBottom="2dp" />
                            <TextView android:id="@+id/tvDetailDaerah" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="-"
                                android:textColor="#1A1A1A" android:textSize="15sp" android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" android:layout_marginBottom="16dp" />

                    <!-- Kategori -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
                            android:background="@drawable/bg_icon_circle" android:layout_marginEnd="14dp">
                            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                                android:layout_gravity="center" android:src="@drawable/ic_kategoribarang"
                                app:tint="#0D5C3A" android:contentDescription="Kategori" />
                        </FrameLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="KATEGORI" android:textColor="#AAAAAA"
                                android:textSize="10sp" android:letterSpacing="0.06" android:layout_marginBottom="4dp" />
                            <TextView android:id="@+id/tvDetailKategori" android:layout_width="wrap_content"
                                android:layout_height="wrap_content" android:text="MEMBER ✦"
                                android:background="@drawable/bg_chip_green"
                                android:paddingHorizontal="10dp" android:paddingVertical="5dp"
                                android:textColor="#0D5C3A" android:textSize="12sp" android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
