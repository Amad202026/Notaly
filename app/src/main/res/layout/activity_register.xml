<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAF9">

    <!-- Header strip hijau -->
    <View
        android:id="@+id/viewHeader"
        android:layout_width="0dp"
        android:layout_height="6dp"
        android:background="#0D5C3A"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- White card utama -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_card_full"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="24dp"
        android:paddingHorizontal="28dp"
        android:paddingTop="36dp"
        android:paddingBottom="32dp"
        app:layout_constraintTop_toBottomOf="@id/viewHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Icon -->
        <ImageView
            android:id="@+id/ivIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_daftartransaksi"
            android:contentDescription="Icon"
            android:background="@drawable/bg_icon_circle"
            android:padding="10dp"
            android:scaleType="fitCenter"
            app:tint="#0D5C3A"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Badge -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_green"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="AKUN BARU"
            android:textColor="#0D5C3A"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/ivIcon"
            app:layout_constraintBottom_toBottomOf="@id/ivIcon" />

        <!-- Judul -->
        <TextView
            android:id="@+id/tvJudul"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Selamat Datang"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1A2E25"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivIcon" />

        <!-- Subjudul -->
        <TextView
            android:id="@+id/tvSubJudul"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Buat PIN owner untuk melindungi akun Anda"
            android:textSize="14sp"
            android:textColor="#6B7A72"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvJudul" />

        <!-- Divider -->
        <View
            android:id="@+id/viewLine"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="28dp"
            android:background="#E8EDE9"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSubJudul" />

        <!-- Label PIN -->
        <TextView
            android:id="@+id/tvLabelPin"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Buat 4 Digit PIN Baru"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#3D5249"
            android:letterSpacing="0.03"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/viewLine" />

        <!-- Input PIN -->
        <LinearLayout
            android:id="@+id/linearLayout"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvLabelPin">

            <EditText
                android:id="@+id/etPin"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_input_outline"
                android:gravity="center"
                android:hint="● ● ● ●"
                android:imeOptions="actionDone"
                android:inputType="numberPassword"
                android:singleLine="true"
                android:textColor="#1A2E25"
                android:maxLength="4"
                android:textColorHint="#B0BDB7"
                android:textSize="18sp"
                android:paddingHorizontal="16dp"
                android:letterSpacing="0.4" />
        </LinearLayout>

        <!-- Info hint -->
        <LinearLayout
            android:id="@+id/llInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_info_strip"
            android:paddingHorizontal="12dp"
            android:paddingVertical="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/linearLayout">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_warning"
                android:contentDescription="Info"
                app:tint="#0D5C3A"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="PIN digunakan untuk mengakses aplikasi ini"
                android:textColor="#3D5249"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Tombol REGISTER -->
        <TextView
            android:id="@+id/btnRegister"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_btn_hijau_round"
            android:gravity="center"
            android:text="Buat Akun"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>