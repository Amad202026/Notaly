<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <FrameLayout
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/bg_icon_circle_large"
                android:layout_marginEnd="14dp">

                <TextView
                    android:id="@+id/tvInisialSupplier"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    tools:text="M"
                    android:textColor="#0D5C3A"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvKategoriPill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="ALAT OLAHRAGA"
                    android:textColor="#0D5C3A"
                    android:textSize="9sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_chip_green"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:layout_marginBottom="4dp"
                    android:letterSpacing="0.04" />

                <TextView
                    android:id="@+id/tvNamaSupplier"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:text="Mahkota Sport"
                    android:textColor="#1A1A1A"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

            <ImageView
                android:id="@+id/btnDelete"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:contentDescription="Hapus"
                android:src="@drawable/ic_delete"
                app:tint="#E53935" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F5F5F5"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_phone"
                app:tint="#0D5C3A"
                android:layout_marginEnd="8dp"
                android:contentDescription="Telepon" />

            <TextView
                android:id="@+id/tvNoTelp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:text="+62 811-2233-4455"
                android:textColor="#444444"
                android:textSize="13sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/btnDetail"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_btn_hijau_round"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="Detail"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>
</androidx.cardview.widget.CardView>