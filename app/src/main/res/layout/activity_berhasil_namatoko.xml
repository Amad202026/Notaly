<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:paddingHorizontal="24dp">

    <!-- Icon Sukses -->
    <FrameLayout
        android:id="@+id/frameIconSukses"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:background="@drawable/bg_btn_hijau"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvJudul"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.42">

        <!-- Lingkaran putih transparan di dalam kotak hijau -->
        <FrameLayout
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center"
            android:background="@drawable/ic_cheklis_full_green"/>
    </FrameLayout>

    <!-- Judul -->
    <TextView
        android:id="@+id/tvJudul"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="36dp"
        android:text="Berhasil Ganti Nama Toko"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/frameIconSukses"
        app:layout_constraintBottom_toTopOf="@id/tvDeskripsi" />

    <!-- Deskripsi -->
    <TextView
        android:id="@+id/tvDeskripsi"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="8dp"
        android:text="Nama Toko Anda telah diperbarui."
        android:textSize="15sp"
        android:textColor="#666666"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvJudul"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0" />

    <!-- Tombol Kembali ke Pengaturan -->
    <Button
        android:id="@+id/btnKembali"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_btn_hijau"
        android:text="Kembali ke Pengaturan"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="normal"
        android:letterSpacing="0.01"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>