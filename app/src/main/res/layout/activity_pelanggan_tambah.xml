<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#FFFFFF"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="16dp"
            android:elevation="2dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Kembali"
                android:padding="12dp"
                app:tint="#1A1A1A" />

            <TextView
                android:id="@+id/tvTopBarJudul"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TAMBAH PELANGGAN"
                android:textColor="#333333"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvJudul"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tambah Pelanggan"
                android:textColor="#1A1A1A"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manajemen database pelanggan"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_marginBottom="20dp" />

            <!-- ID Pelanggan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ID PELANGGAN"
                android:textColor="#555555"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvIdPelanggan"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:gravity="center_vertical"
                android:text="Otomatis"
                android:textColor="#AAAAAA"
                android:background="@drawable/bg_search_rounded"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="12dp" />

            <!-- Nama Lengkap -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NAMA LENGKAP"
                android:textColor="#555555"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etNamaLengkap"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Contoh: Budi Santoso"
                android:background="@drawable/bg_search_rounded"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="12dp"
                android:inputType="textPersonName" />

            <!-- Nomor WhatsApp -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NOMOR WHATSAPP"
                android:textColor="#555555"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etNomorWA"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="+62 812-3456-7890"
                android:inputType="phone"
                android:background="@drawable/bg_search_rounded"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="12dp" />

            <!-- Asal Daerah -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ASAL DAERAH"
                android:textColor="#555555"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etAsalDaerah"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Kota/Kabupaten"
                android:background="@drawable/bg_search_rounded"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="12dp" />

            <!-- Kategori Pelanggan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KATEGORI PELANGGAN"
                android:textColor="#555555"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <Spinner
                android:id="@+id/spinnerKategori"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_search_rounded"
                android:paddingStart="12dp"
                android:layout_marginBottom="24dp" />

            <!-- Buttons -->
            <Button
                android:id="@+id/btnBatal"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="BATAL"
                android:backgroundTint="#DDDDDD"
                android:textColor="#333333"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnSimpanPelanggan"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="SIMPAN PELANGGAN"
                android:backgroundTint="#2D6A4F"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>