<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAF9"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header strip hijau -->
        <View
            android:id="@+id/viewHeader"
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:background="#0D5C3A"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- White card utama -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/clCard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_card_full"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="24dp"
            android:paddingHorizontal="28dp"
            android:paddingTop="36dp"
            android:paddingBottom="32dp"
            app:layout_constraintTop_toBottomOf="@id/viewHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Icon -->
            <ImageView
                android:id="@+id/ivIcon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_daftartransaksi"
                android:contentDescription="Icon"
                android:background="@drawable/bg_icon_circle"
                android:padding="10dp"
                android:scaleType="fitCenter"
                app:tint="#0D5C3A"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Judul -->
            <TextView
                android:id="@+id/tvJudul"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Selamat Datang"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#1A2E25"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/ivIcon" />

            <!-- Subjudul -->
            <TextView
                android:id="@+id/tvSubJudul"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Lengkapi detail toko Anda untuk melanjutkan"
                android:textSize="14sp"
                android:textColor="#6B7A72"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvJudul" />

            <!-- Divider -->
            <View
                android:id="@+id/viewLine"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginTop="28dp"
                android:background="#E8EDE9"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvSubJudul" />

            <!-- === SECTION: Nama Toko === -->
            <TextView
                android:id="@+id/tvNamaToko"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Nama Toko"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#3D5249"
                android:letterSpacing="0.03"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/viewLine" />

            <LinearLayout
                android:id="@+id/llNamaToko"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvNamaToko">

                <EditText
                    android:id="@+id/etNamaToko"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_input_outline"
                    android:hint="Masukkan nama toko"
                    android:paddingHorizontal="16dp"
                    android:inputType="text"
                    android:singleLine="true"
                    android:textColor="#1A2E25"
                    android:textColorHint="#B0BDB7"
                    android:textSize="15sp" />
            </LinearLayout>

            <!-- === SECTION: Tanggal Lahir === -->
            <TextView
                android:id="@+id/tvTanggalLahir"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Tanggal Lahir"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#3D5249"
                android:letterSpacing="0.03"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/llNamaToko" />

            <TextView
                android:id="@+id/tvHintTanggal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Digunakan untuk verifikasi identitas"
                android:textSize="12sp"
                android:textColor="#A0AEA7"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvTanggalLahir" />

            <LinearLayout
                android:id="@+id/llTanggalLahir"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:weightSum="8"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvHintTanggal">

                <!-- DD -->
                <Spinner
                    android:id="@+id/spHariLahir"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="2"
                    android:background="@drawable/bg_input_outline"
                    android:hint="DD"
                    android:gravity="center"
                    android:inputType="number"
                    android:singleLine="true"
                    android:textColor="#1A2E25"
                    android:textColorHint="#B0BDB7"
                    android:textSize="15sp"
                    android:maxLength="2" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="/"
                    android:textSize="20sp"
                    android:textColor="#6B7A72"
                    android:textStyle="bold" />

                <!-- MM -->
                <Spinner
                    android:id="@+id/spBulanLahir"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="2"
                    android:background="@drawable/bg_input_outline"
                    android:hint="MM"
                    android:gravity="center"
                    android:inputType="number"
                    android:singleLine="true"
                    android:textColor="#1A2E25"
                    android:textColorHint="#B0BDB7"
                    android:textSize="15sp"
                    android:maxLength="2" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="/"
                    android:textSize="20sp"
                    android:textColor="#6B7A72"
                    android:textStyle="bold" />

                <!-- YYYY -->
                <Spinner
                    android:id="@+id/spTahunLahir"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="2"
                    android:background="@drawable/bg_input_outline"
                    android:hint="YYYY"
                    android:gravity="center"
                    android:inputType="number"
                    android:singleLine="true"
                    android:textColor="#1A2E25"
                    android:textColorHint="#B0BDB7"
                    android:textSize="15sp"
                    android:maxLength="4" />
            </LinearLayout>

            <!-- Spacer -->
            <View
                android:id="@+id/viewSpacer"
                android:layout_width="0dp"
                android:layout_height="32dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/llTanggalLahir" />

            <!-- Tombol LOGIN -->
            <TextView
                android:id="@+id/btnLogin"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_btn_hijau_round"
                android:gravity="center"
                android:text="Masuk"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:clickable="true"
                android:focusable="true"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>