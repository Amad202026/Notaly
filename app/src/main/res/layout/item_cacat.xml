<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Baris atas: Nama + Tanggal -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tvNamaBarang"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toStartOf="@id/tvTanggal"
                android:text="Nama Barang"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvTanggal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="01 Jan 2025"
                android:textSize="11sp"
                android:textColor="#AAAAAA" />

        </RelativeLayout>

        <!-- Badge Kategori -->
        <TextView
            android:id="@+id/tvKategori"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kategori"
            android:textSize="10sp"
            android:textColor="#0D5C3A"
            android:textStyle="bold"
            android:background="@drawable/bg_chip_green"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:layout_marginBottom="12dp"
            android:letterSpacing="0.04" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F5F5F5"
            android:layout_marginBottom="12dp" />

        <!-- Stats: Jumlah Cacat + Harga Obral -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <!-- Jumlah Cacat -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_mutasi_out"
                android:orientation="vertical"
                android:padding="10dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="JUMLAH CACAT"
                    android:textSize="9sp"
                    android:textColor="#E53935"
                    android:textStyle="bold"
                    android:letterSpacing="0.06"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tvJumlahCacat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2 Pcs"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#E53935" />

            </LinearLayout>

            <!-- Harga Obral -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_info_strip"
                android:orientation="vertical"
                android:padding="10dp"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HARGA OBRAL"
                    android:textSize="9sp"
                    android:textColor="#0D5C3A"
                    android:textStyle="bold"
                    android:letterSpacing="0.06"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/tvHargaObral"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Rp 50.000"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#0A3D26" />

            </LinearLayout>

        </LinearLayout>

        <!-- Keterangan -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KETERANGAN"
            android:textSize="10sp"
            android:textColor="#AAAAAA"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tvKeterangan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="-"
            android:textSize="13sp"
            android:textColor="#555555"
            android:fontFamily="sans-serif"
            android:lineSpacingExtra="3dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
