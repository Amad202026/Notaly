<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAF9">

    <!-- Hero Banner (gradient block) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clHero"
        android:layout_width="match_parent"
        android:layout_height="330dp"
        android:background="@drawable/bg_hero_green"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Ilustrasi tengah -->
        <ImageView
            android:id="@+id/ivHeader"
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:adjustViewBounds="true"
            android:contentDescription="Ilustrasi Notaly"
            android:scaleType="fitCenter"
            android:src="@drawable/bg_op"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- App Label atas kiri -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="28dp"
            android:layout_marginTop="52dp"
            android:alpha="0.85"
            android:letterSpacing="0.25"
            android:text="NOTALY"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Badge kanan atas -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:layout_marginEnd="28dp"
            android:background="@drawable/bg_badge_white"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"
            android:text="v2.0"
            android:textColor="#0D5C3A"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Content Card -->
    <!-- layout_height diubah ke 0dp agar mengisi sisa layar pas sampai bawah -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/bg_card_top_rounded"
        android:paddingHorizontal="28dp"
        android:paddingTop="32dp"
        android:paddingBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/clHero">

        <!-- Chip label -->
        <TextView
            android:id="@+id/tvOverline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_green"
            android:letterSpacing="0.1"
            android:paddingHorizontal="12dp"
            android:paddingVertical="5dp"
            android:text="MANAJEMEN BISNIS"
            android:textColor="#0D5C3A"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Judul baris 1 -->
        <TextView
            android:id="@+id/tvTitleBlack"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:includeFontPadding="false"
            android:lineSpacingMultiplier="1.1"
            android:text="Kelola Bisnis"
            android:textColor="#1A2E25"
            android:textSize="34sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvOverline" />

        <!-- Judul baris 2 -->
        <TextView
            android:id="@+id/tvTitleGreen"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:lineSpacingMultiplier="1.1"
            android:text="Lebih Pintar\ndengan Notaly"
            android:textColor="#0D5C3A"
            android:textSize="34sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitleBlack" />

        <!-- Deskripsi -->
        <TextView
            android:id="@+id/tvDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:lineSpacingExtra="6dp"
            android:text="Pantau stok, penjualan, dan keuntungan secara real-time — di mana saja, kapan saja."
            android:textColor="#6B7A72"
            android:textSize="15sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitleGreen" />

        <!-- Divider tipis -->
        <View
            android:id="@+id/viewDivider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="24dp"
            android:background="#E8EDE9"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvDescription" />

        <!-- Tombol Get Started -->
        <Button
            android:id="@+id/btnGetStarted"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="24dp"
            android:text="Mulai Sekarang"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#0D5C3A"
            app:cornerRadius="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/viewDivider" />

        <!-- Footer teks -->

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>