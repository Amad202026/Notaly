<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        android:paddingHorizontal="5dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:src="@drawable/ic_arrow_back"
            android:clickable="true"
            android:focusable="true"
            android:scaleType="centerInside"
            android:contentDescription="Kembali"
            app:tint="#2E7D5B"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/ivIcon"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginTop="48dp"
            android:contentDescription="Icon"
            android:src="@drawable/ic_protection"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#2E7D5B" />

        <TextView
            android:id="@+id/tvJudul"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Lupa PIN"
            android:textColor="#2A2A2A"
            android:textSize="30sp"
            android:textStyle="bold"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/ivIcon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvSubJudul"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Verifikasi identitas Anda untuk mengatur ulang PIN"
            android:textColor="#666666"
            android:textSize="13sp"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/tvJudul"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvNamaToko"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="Masukkan nama toko anda"
            android:textColor="#000000"
            android:textSize="14sp"
            android:paddingLeft="32dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvJudul" />

        <LinearLayout
            android:id="@+id/llNamaToko"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:paddingHorizontal="32dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvNamaToko">

            <EditText
                android:id="@+id/etNamaToko"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="5dp"
                android:background="@drawable/bg_search_rounded"
                android:hint="Nama Toko"
                android:paddingLeft="10dp"
                android:inputType="text"
                android:singleLine="true"
                android:textColor="#1A1A1A"
                android:textColorHint="#AAAAAA"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTanggalLahir"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Masukkan tanggal lahir anda"
            android:textColor="#000000"
            android:textSize="14sp"
            android:paddingLeft="32dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/llNamaToko" />

        <LinearLayout
            android:id="@+id/llTanggalLahir"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:weightSum="5"
            android:paddingHorizontal="32dp"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTanggalLahir">

            <EditText
                android:id="@+id/etHariLahir"
                android:layout_width="30dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="@drawable/bg_search_rounded"
                android:hint="dd"
                android:gravity="center"
                android:inputType="number"
                android:singleLine="true"
                android:textColor="#1A1A1A"
                android:textColorHint="#AAAAAA"
                android:textSize="14sp" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:layout_margin="5dp"
                android:text="-"
                android:textSize="35dp"/>
            <EditText
                android:id="@+id/etBulanLahir"
                android:layout_width="30dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="@drawable/bg_search_rounded"
                android:hint="mm"
                android:gravity="center"
                android:inputType="number"
                android:singleLine="true"
                android:textColor="#1A1A1A"
                android:textColorHint="#AAAAAA"
                android:textSize="14sp" />
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:layout_margin="5dp"
                android:text="-"
                android:textSize="35dp"/>
            <EditText
                android:id="@+id/etTahunLahir"
                android:layout_width="30dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="5dp"
                android:background="@drawable/bg_search_rounded"
                android:hint="yy"
                android:gravity="center"
                android:inputType="number"
                android:singleLine="true"
                android:textColor="#1A1A1A"
                android:textColorHint="#AAAAAA"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/btnVerifikasi"
            android:layout_width="0dp"
            android:layout_height="54dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/bg_btn_hijau"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:layout_marginVertical="350dp"
            android:layout_marginHorizontal="32dp"
            android:letterSpacing="0.08"
            android:text="Verifikasi dan Reset PIN"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>