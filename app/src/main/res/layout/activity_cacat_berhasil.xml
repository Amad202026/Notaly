<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:paddingHorizontal="24dp">

    <!-- Icon Sukses -->
    <FrameLayout
        android:id="@+id/frameIconSukses"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:background="@drawable/bg_btn_hijau"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvJudul"
        app:layout_constraintVertical_chainStyle="packed"
        app:layout_constraintVertical_bias="0.13">

        <FrameLayout
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center"
            android:background="@drawable/ic_checklis_half_green">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_cheklis"
                android:scaleType="centerInside"
                android:contentDescription="Berhasil"
                app:tint="#2E7D5B" />
        </FrameLayout>
    </FrameLayout>

    <!-- Judul -->
    <TextView
        android:id="@+id/tvJudul"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Laporan berhasil Disimpan"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/frameIconSukses"
        app:layout_constraintBottom_toTopOf="@id/tvDeskripsi" />

    <!-- Deskripsi -->
    <TextView
        android:id="@+id/tvDeskripsi"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Data barang cacat telah berhasil dicatat."
        android:textSize="14sp"
        android:textColor="#888888"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvJudul"
        app:layout_constraintBottom_toTopOf="@id/cardRingkasan" />

    <!-- Card Ringkasan Laporan -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardRingkasan"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#F4F7F5"
        app:layout_constraintTop_toBottomOf="@id/tvDeskripsi"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnInputLagi">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Label Ringkasan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RINGKASAN LAPORAN"
                android:textSize="12sp"
                android:textColor="#2E7D5B"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:layout_marginBottom="16dp" />

            <!-- Nama Barang -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NAMA BARANG"
                android:textSize="11sp"
                android:textColor="#888888"
                android:letterSpacing="0.04"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvNamaBarang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jersey Borneo Fc"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="16dp" />

            <!-- Jumlah & Kategori (side by side) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="JUMLAH"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:letterSpacing="0.04"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvJumlah"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 Pcs"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KATEGORI"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:letterSpacing="0.04"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvKategori"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Baju"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A" />
                </LinearLayout>
            </LinearLayout>

            <!-- Catatan Kerusakan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CATATAN KERUSAKAN"
                android:textSize="11sp"
                android:textColor="#888888"
                android:letterSpacing="0.04"
                android:layout_marginBottom="10dp" />

            <!-- Box catatan -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF">

                <TextView
                    android:id="@+id/tvCatatanKerusakan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:text="Kerah Robek pada jahitan sisi kiri"
                    android:textSize="14sp"
                    android:textStyle="italic"
                    android:textColor="#444444"
                    android:lineSpacingExtra="3dp" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Tombol Input Lagi -->

    <!-- Tombol Lihat Laporan -->

    <Button
        android:id="@+id/btnInputLagi"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="48dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_btn_hijau"
        android:drawableStart="@drawable/ic_plus"
        android:drawablePadding="8dp"
        android:text="Input Lagi"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/btnLihatLaporan"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btnLihatLaporan"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginBottom="28dp"
        android:background="@drawable/bg_btn_hijau"
        android:text="Lihat Laporan"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>