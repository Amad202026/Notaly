<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F6F4">

    <!-- ===================== ILUSTRASI SUKSES ===================== -->
    <LinearLayout
        android:id="@+id/successBlock"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="32dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/cardRingkasan"
        app:layout_constraintVertical_bias="0.5"
        app:layout_constraintVertical_chainStyle="packed">

        <!-- Icon lingkaran besar -->
        <FrameLayout
            android:id="@+id/frameIconSukses"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:background="@drawable/bg_icon_circle_large">

            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_cheklis"
                android:contentDescription="Berhasil" />
        </FrameLayout>

        <!-- Badge chip -->

        <!-- Judul -->
        <TextView
            android:id="@+id/tvJudul"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Laporan Berhasil Disimpan"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#0A3D26"
            android:gravity="center" />

        <!-- Deskripsi -->
        <TextView
            android:id="@+id/tvDeskripsi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Data barang cacat telah berhasil dicatat."
            android:textSize="14sp"
            android:textColor="#666666"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>

    <!-- Card Ringkasan Laporan -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardRingkasan"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/successBlock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnInputLagi">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Label Ringkasan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RINGKASAN LAPORAN"
                android:textSize="11sp"
                android:textColor="#0D5C3A"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:layout_marginBottom="16dp" />

            <!-- Nama Barang -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NAMA BARANG"
                android:textSize="11sp"
                android:textColor="#888888"
                android:letterSpacing="0.04"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvNamaBarang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jersey Borneo Fc"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"
                android:layout_marginBottom="16dp" />

            <!-- Jumlah & Kategori (side by side) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="JUMLAH"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:letterSpacing="0.04"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvJumlah"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 Pcs"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KATEGORI"
                        android:textSize="11sp"
                        android:textColor="#888888"
                        android:letterSpacing="0.04"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tvKategori"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Baju"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A" />
                </LinearLayout>
            </LinearLayout>

            <!-- Catatan Kerusakan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CATATAN KERUSAKAN"
                android:textSize="11sp"
                android:textColor="#888888"
                android:letterSpacing="0.04"
                android:layout_marginBottom="8dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F4F7F5">

                <TextView
                    android:id="@+id/tvCatatanKerusakan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:text="Kerah Robek pada jahitan sisi kiri"
                    android:textSize="14sp"
                    android:textStyle="italic"
                    android:textColor="#444444"
                    android:lineSpacingExtra="3dp" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Tombol Input Lagi -->
    <TextView
        android:id="@+id/btnInputLagi"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_white_rounded"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="Input Lagi"
        android:textColor="#0D5C3A"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/btnLihatLaporan"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Tombol Lihat Laporan -->
    <TextView
        android:id="@+id/btnLihatLaporan"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="28dp"
        android:background="@drawable/bg_btn_hijau_round"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="Lihat Laporan"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
