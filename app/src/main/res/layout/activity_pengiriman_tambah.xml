<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="#F2F6F4">

    <!-- ===================== HERO HEADER ===================== -->
    <LinearLayout
        android:id="@+id/headerSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_hero_green"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_badge_white"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back"
                android:clickable="true"
                android:focusable="true"
                android:scaleType="centerInside"
                android:contentDescription="Kembali"
                android:layout_marginEnd="14dp"
                tools:ignore="TouchTargetSizeCheck"
                app:tint="#0D5C3A" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvJudul"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manajemen Logistik"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Catat data pengiriman barang"
                    android:textSize="12sp"
                    android:textColor="#A8D5BC" />

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ===================== SCROLL FORM ===================== -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/headerSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnSimpan">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_top_rounded"
            android:paddingHorizontal="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">

            <!-- SECTION 1: IDENTITAS PENGIRIMAN -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                <View android:layout_width="3dp" android:layout_height="16dp"
                    android:background="@drawable/bg_btn_hijau_round" android:layout_marginEnd="10dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="IDENTITAS PENGIRIMAN" android:textSize="10sp"
                    android:textColor="#0D5C3A" android:textStyle="bold" android:letterSpacing="0.08" />
            </LinearLayout>

            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="20dp" app:cardCornerRadius="20dp" app:cardElevation="0dp" app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ID TRANSAKSI" android:textSize="10sp" android:textColor="#0D5C3A"
                        android:textStyle="bold" android:letterSpacing="0.08" android:layout_marginBottom="8dp" />

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="56dp"
                        android:background="@drawable/bg_input_outline">
                        <Spinner android:id="@+id/spinnerIdTransaksi" android:layout_width="match_parent"
                            android:layout_height="match_parent" android:paddingStart="16dp" android:paddingEnd="40dp"
                            android:background="@null" android:spinnerMode="dropdown" />
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:layout_alignParentEnd="true" android:layout_centerVertical="true"
                            android:layout_marginEnd="14dp" android:src="@drawable/ic_arrow_down"
                            android:contentDescription="Dropdown" app:tint="#AAAAAA" />
                    </RelativeLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SECTION 2: DETAIL EKSPEDISI -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                <View android:layout_width="3dp" android:layout_height="16dp"
                    android:background="@drawable/bg_btn_hijau_round" android:layout_marginEnd="10dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="DETAIL EKSPEDISI" android:textSize="10sp"
                    android:textColor="#0D5C3A" android:textStyle="bold" android:letterSpacing="0.08" />
            </LinearLayout>

            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="20dp" app:cardCornerRadius="20dp" app:cardElevation="0dp" app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">

                    <!-- Nama Ekspedisi -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="NAMA EKSPEDISI" android:textSize="10sp" android:textColor="#0D5C3A"
                        android:textStyle="bold" android:letterSpacing="0.08" android:layout_marginBottom="8dp" />

                    <EditText android:id="@+id/etNamaEkspedisi" android:layout_width="match_parent"
                        android:layout_height="56dp" android:background="@drawable/bg_input_outline"
                        android:paddingHorizontal="16dp" android:hint="Contoh: J&amp;T Express, JNE, SiCepat"
                        android:textSize="14sp" android:textColor="#1A1A1A" android:textColorHint="#BBBBBB"
                        android:inputType="text" android:singleLine="true" android:gravity="center_vertical"
                        android:layout_marginBottom="16dp" />

                    <!-- Nomor Resi -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="NOMOR RESI" android:textSize="10sp" android:textColor="#0D5C3A"
                        android:textStyle="bold" android:letterSpacing="0.08" android:layout_marginBottom="8dp" />

                    <EditText android:id="@+id/etNomorResi" android:layout_width="match_parent"
                        android:layout_height="56dp" android:background="@drawable/bg_input_outline"
                        android:paddingHorizontal="16dp" android:hint="Masukkan nomor resi..."
                        android:textSize="14sp" android:textColor="#1A1A1A" android:textColorHint="#BBBBBB"
                        android:inputType="text" android:singleLine="true" android:gravity="center_vertical"
                        android:layout_marginBottom="16dp" />

                    <!-- Alamat Tujuan -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ALAMAT LENGKAP TUJUAN" android:textSize="10sp" android:textColor="#0D5C3A"
                        android:textStyle="bold" android:letterSpacing="0.08" android:layout_marginBottom="8dp" />

                    <EditText android:id="@+id/etAlamatTujuan" android:layout_width="match_parent"
                        android:layout_height="96dp" android:background="@drawable/bg_input_outline"
                        android:paddingHorizontal="16dp" android:paddingVertical="14dp"
                        android:hint="Jl. Palaran No. 17, Samarinda..." android:inputType="textMultiLine"
                        android:textSize="14sp" android:textColor="#1A1A1A" android:textColorHint="#BBBBBB"
                        android:gravity="top|start" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SECTION 3: STATUS & ADMINISTRASI -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                <View android:layout_width="3dp" android:layout_height="16dp"
                    android:background="@drawable/bg_btn_hijau_round" android:layout_marginEnd="10dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="STATUS &amp; ADMINISTRASI" android:textSize="10sp"
                    android:textColor="#0D5C3A" android:textStyle="bold" android:letterSpacing="0.08" />
            </LinearLayout>

            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" app:cardCornerRadius="20dp" app:cardElevation="0dp" app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">

                    <!-- Biaya Kirim -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="BIAYA KIRIM" android:textSize="10sp" android:textColor="#0D5C3A"
                        android:textStyle="bold" android:letterSpacing="0.08" android:layout_marginBottom="8dp" />

                    <FrameLayout android:layout_width="match_parent" android:layout_height="56dp"
                        android:background="@drawable/bg_input_green_outline" android:layout_marginBottom="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical|start" android:layout_marginStart="16dp"
                            android:text="Rp" android:textSize="14sp" android:textColor="#0D5C3A" />
                        <EditText android:id="@+id/etBiayaKirim" android:layout_width="match_parent"
                            android:layout_height="match_parent" android:paddingStart="44dp" android:paddingEnd="16dp"
                            android:hint="0" android:inputType="numberDecimal" android:textSize="15sp"
                            android:textStyle="bold" android:textColor="#0D5C3A" android:textColorHint="#BBBBBB"
                            android:background="@null" android:gravity="center_vertical" />
                    </FrameLayout>

                    <!-- Status Pengiriman -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="STATUS PENGIRIMAN" android:textSize="10sp" android:textColor="#0D5C3A"
                        android:textStyle="bold" android:letterSpacing="0.08" android:layout_marginBottom="8dp" />

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="56dp"
                        android:background="@drawable/bg_input_outline">
                        <Spinner android:id="@+id/spinnerStatusPengiriman" android:layout_width="match_parent"
                            android:layout_height="match_parent" android:paddingStart="16dp" android:paddingEnd="40dp"
                            android:background="@null" android:spinnerMode="dropdown" />
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:layout_alignParentEnd="true" android:layout_centerVertical="true"
                            android:layout_marginEnd="14dp" android:src="@drawable/ic_arrow_down"
                            android:contentDescription="Dropdown" app:tint="#AAAAAA" />
                    </RelativeLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- TOMBOL SIMPAN -->
    <TextView
        android:id="@+id/btnSimpan"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="28dp"
        android:background="@drawable/bg_btn_hijau_round"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="Simpan Data Pengiriman"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
