<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <ImageView
        android:id="@+id/ivCoverToko"
        android:layout_width="0dp"
        android:layout_height="140dp"
        android:background="#0D5C3A"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <FrameLayout
        android:id="@+id/flWadahProfil"
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:layout_marginStart="24dp"
        app:layout_constraintBottom_toBottomOf="@id/ivCoverToko"
        app:layout_constraintTop_toBottomOf="@id/ivCoverToko"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/ivFotoProfil"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#CCCCCC" />

        <View
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="4dp"
            android:background="#4CAF50" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvNamaToko"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:text="Toko Maju Terus"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        app:layout_constraintStart_toEndOf="@id/flWadahProfil"
        app:layout_constraintTop_toBottomOf="@id/ivCoverToko" />

    <LinearLayout
        android:id="@+id/llInfoPengikut"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="4dp"
        android:orientation="horizontal"
        app:layout_constraintStart_toEndOf="@id/flWadahProfil"
        app:layout_constraintTop_toBottomOf="@id/tvNamaToko">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10.5K Pengikut"
            android:textSize="12sp"
            android:textColor="#666666" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="45 Mengikuti"
            android:textSize="12sp"
            android:textColor="#666666" />
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/cvWadahPencarian"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/flWadahProfil"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/etCariProduk"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:paddingHorizontal="16dp"
            android:background="@android:color/transparent"
            android:hint="Cari produk di toko ini..."
            android:textSize="14sp"
            android:inputType="text" />
    </androidx.cardview.widget.CardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDaftarProduk"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/cvWadahPencarian"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>